<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Realms - Battle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css?v=1.2">
    <link rel="stylesheet" href="/css/game.css?v=1.4">
    <link rel="stylesheet" href="https://cdn.hugeicons.com/font/hgi-stroke-rounded.css">
</head>

<body style="background: url('/assets/background1.png') no-repeat center center fixed; background-size: cover;">
    <canvas id="bg-particles"
        style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>
    <canvas id="canvas-effects"></canvas>
    
    <!-- Spectator Mode Banner -->
    <div id="spectator-banner" class="spectator-banner hidden" style="position: fixed; top: 0; left: 50%; transform: translateX(-50%); background: linear-gradient(90deg, rgba(147, 51, 234, 0.92), rgba(76, 29, 149, 0.92)); border: 1px solid rgba(167, 139, 250, 0.45); border-top: none; padding: 10px 30px; border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; color: #fff; font-family: 'Outfit', sans-serif; font-size: 0.95rem; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; z-index: 1000; box-shadow: 0 4px 20px rgba(0,0,0,0.5); animation: slideDown 0.5s cubic-bezier(0.1, 0.8, 0.3, 1);">
        <span style="font-size: 1.2rem; display: inline-block;">👁️</span> Spectator Mode
    </div>

    <style>
        .spectator-banner {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .spectator-banner.hidden {
            display: none !important;
        }
        @keyframes slideDown {
            from {
                transform: translate(-50%, -100%);
            }
            to {
                transform: translate(-50%, 0);
            }
        }
    </style>
    
    <button id="leave-battle-btn" class="leave-battle-btn"> Leave Battle </button>

    <!-- Custom Confirmation Modal -->
    <div id="leave-confirm-modal" class="modal-overlay hidden">
        <div class="modal-content">
            <h2>Surrender?</h2>
            <p>Are you sure you want to leave the battle? This will be counted as a loss.</p>
            <div class="modal-actions">
                <button id="confirm-leave-btn" class="confirm-btn">Yes, Surrender</button>
                <button id="cancel-leave-btn" class="cancel-btn">No, Continue</button>
            </div>
        </div>
    </div>

    <!-- Ability Announcement Overlay -->
    <div id="ability-announcement" class="ability-announcement hidden">
        <div class="announcement-content">
            <span class="announcement-label">YOUR SUPER ABILITY</span>
            <div class="ability-card-showcase">
                <img id="announced-ability-img" src="" alt="Ability">
                <div class="ability-info-large">
                    <h2 id="announced-ability-name">Ability Name</h2>
                    <p id="announced-ability-desc">Ability Description</p>
                </div>
            </div>
            <button id="close-announcement-btn" class="close-announcement-btn">READY TO BATTLE</button>
        </div>
    </div>

    <div class="battlefield-container">
        <!-- Opponent Area -->
        <div class="player-area opponent-area">
            <div class="player-info">
                <img src="/assets/default_avatar.png" alt="Opponent" id="opp-avatar" class="avatar">
                <div>
                    <h3 id="opp-nickname">Opponent</h3>
                    <div class="hp-container" style="display: flex; align-items: center; gap: 10px;">
                        <div class="hp-bar">
                            <div id="opp-hp-fill" class="hp-fill"></div>
                        </div>
                        <span class="hp-text">20/20</span>
                    </div>
                    <span class="energy-display">Energy: <span id="opp-energy">0/0</span></span>
                </div>
                <div class="lightning-overlay"></div>
            </div>
        </div>

        <!-- Battlefield -->
        <div class="battlefield">
            <div class="field-side" id="opp-field">
                <!-- Opponent active cards -->
            </div>

            <div class="battle-center">
                <div id="turn-indicator" class="turn-indicator">Opponent's Turn</div>
                <div class="timer-overlay" id="timer">30</div>
            </div>

            <div class="field-side" id="my-field">
                <!-- My active cards -->
            </div>
        </div>

        <!-- My Area -->
        <div class="player-area">
            <div class="hand-container">
                <div id="my-ability-btn" class="ability-container my-ability disabled" title="Use Super Ability">
                    <img id="my-ability-img" src="" alt="Ability" class="ability-icon">
                    <div id="my-ability-cooldown" class="ability-cooldown hidden">0</div>
                    <div class="ability-tooltip">
                        <strong id="tooltip-ability-name">Ability</strong>
                        <p id="tooltip-ability-desc">Description</p>
                        <span class="cooldown-info">Cooldown: <span id="tooltip-ability-cd">2</span> rounds</span>
                    </div>
                </div>
                <div class="hand-separator"></div>
                <div class="hand" id="my-hand">
                    <!-- Cards in hand -->
                </div>
                <div class="side-actions">
                    <button id="trash-btn" class="side-btn" title="Trash one card (3 left)">
                        <span class="icon"><i class="hgi hgi-stroke hgi-restore-bin"></i></span>
                        <span id="trash-count" class="count">3</span>
                    </button>
                    <button id="change-hand-btn" class="side-btn" title="Change all cards (1 left)">
                        <span class="icon"><i class="hgi hgi-stroke hgi-reload"></i></span>
                        <span id="change-count" class="count">1</span>
                    </button>
                </div>
            </div>
            <div class="player-info">
                <img src="/assets/default_avatar.png" alt="Me" id="my-avatar" class="avatar">
                <div>
                    <h3 id="my-nickname">
                        <%= nickname %>
                    </h3>
                    <div class="hp-container" style="display: flex; align-items: center; gap: 10px;">
                        <div class="hp-bar">
                            <div id="my-hp-fill" class="hp-fill"></div>
                        </div>
                        <span class="hp-text">20/20</span>
                    </div>
                    <span class="energy-display">Energy: <span id="my-energy">0/0</span></span>
                </div>
                <button id="end-turn-btn" class="end-turn-btn">End Turn</button>
                <div class="lightning-overlay"></div>
            </div>
        </div>

    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const nickname = "<%= nickname %>";
        const myUserId = "<%= userId %>";
        window.isSpectator = false;
    </script>
    <script src="/js/particles.js"></script>
    <script src="/js/volume-controls.js"></script>
    <script src="/js/emojis.js"></script>
    <script src="/js/game.js"></script>
</body>

</html>
