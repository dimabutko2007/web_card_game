<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Realms - Password Reminder</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>

<body class="auth-page">
    <canvas id="bg-particles" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>
    <div class="auth-wrapper">
        <div class="auth-card">
            <h1>Dark Realms</h1>
            <p style="text-align: center; margin-bottom: 20px; color: #aaa;">Password Recovery</p>

            <% if (locals.error) { %>
                <div class="error-msg">
                    <%= error %>
                </div>
                <% } %>

                    <% if (locals.success) { %>
                        <div
                            style="background: rgba(46, 204, 113, 0.2); color: #2ecc71; padding: 15px; border-radius: 10px; margin-bottom: 20px; text-align: center; border: 1px solid rgba(46, 204, 113, 0.3);">
                            <%= success %>
                        </div>
                        <% } %>

                            <form action="/auth/password-reminder" method="POST">
                                <div class="form-group">
                                    <label for="email">Enter your Email</label>
                                    <input type="email" id="email" name="email" required autocomplete="off">
                                </div>
                                <button type="submit" class="btn">Send Password</button>
                            </form>

                            <div class="auth-footer">
                                Remembered it? <a href="/auth/login">Back to Login</a>
                            </div>
        </div>
    </div>
    <script>
        // Clean URL parameters on load to prevent state preservation on refresh
        if (window.history.replaceState) {
            const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
            window.history.replaceState({ path: cleanUrl }, '', cleanUrl);
        }
    </script>
    <script src="/js/particles.js"></script>
</body>

</html>