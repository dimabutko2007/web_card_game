<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Realms - Reset Password</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css?v=1.2">
</head>

<body class="auth-page">
    <canvas id="bg-particles" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>
    <div class="auth-wrapper">
        <div class="auth-card">
            <h1>Dark Realms</h1>
            <p style="text-align: center; margin-bottom: 20px; color: #aaa;">Set New Password</p>

            <% if (locals.error) { %>
                <div class="error-msg">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/auth/reset-password" method="POST">
                        <input type="hidden" name="token" value="<%= token %>">
                        <div class="form-group">
                            <label for="password">New Password</label>
                            <input type="password" id="password" name="password" required minlength="8"
                                placeholder="Enter new password">
                        </div>
                        <button type="submit" class="btn">Update Password</button>
                    </form>

                    <div class="auth-footer">
                        <a href="/auth/login">Back to Login</a>
                    </div>
        </div>
    </div>
    <script>
        // Clean URL parameters on load to prevent state preservation on refresh
        if (window.history.replaceState) {
            const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
            window.history.replaceState({ path: cleanUrl }, '', cleanUrl);
        }
    </script>
    <script src="/js/particles.js"></script>
    <script src="/js/volume-controls.js"></script>
<script src="/js/sounds.js"></script>
</body>

</html>
