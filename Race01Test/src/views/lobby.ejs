<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Realms - Lobby</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css?v=1.2">
    <link rel="stylesheet" href="/css/achievements.css?v=1.7">
    <style>
        .lobby-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
            margin-top: 50px;
        }

        .user-panel {
            background: rgba(40, 0, 70, 0.35);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(140, 60, 200, 0.25);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
            padding: 30px 60px;
            border-radius: 27px;
            display: flex;
            align-items: center;
            gap: 40px;
            animation: fadeIn 0.8s ease-out;
        }

        .user-panel img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 3px solid rgba(140, 60, 200, 0.7);
            box-shadow: 0 0 15px rgba(140, 60, 200, 0.5);
            object-fit: cover;
        }

        .user-info h2 {
            margin: 0;
            font-size: 2rem;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
        }

        .user-info p {
            color: rgba(255, 255, 255, 0.7);
            margin: 8px 0 0 0;
            font-size: 1.2rem;
        }

        .lobby-actions {
            display: flex;
            gap: 20px;
        }

        .match-btn {
            padding: 20px 60px;
            font-size: 1.5rem;
            width: 100%;
        }

        .match-btn.searching {
            background: var(--color-grey);
            cursor: not-allowed;
        }

        .nav-links {
            position: absolute;
            top: 20px;
            right: 20px;
            display: flex;
            gap: 20px;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 1.4rem;
            opacity: 0.8;
            transition: opacity 0.3s;
        }

        .nav-links a:hover {
            opacity: 1;
            color: var(--color-gold);
        }

        #status-msg {
            margin-top: 20px;
            font-style: italic;
            color: var(--color-gold);
            height: 24px;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
                color: var(--color-gold);
            }

            50% {
                transform: scale(1.2);
                color: #fff;
                text-shadow: 0 0 10px var(--color-gold);
            }

            100% {
                transform: scale(1);
                color: var(--color-gold);
            }
        }

        .leaderboard-panel {
            background: rgba(40, 0, 70, 0.35);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(140, 60, 200, 0.25);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
            padding: 30px;
            border-radius: 27px;
            animation: fadeIn 0.8s ease-out;
            color: white;
        }

        .leaderboard-panel h3 {
            margin-top: 0;
            text-align: center;
            font-size: 2rem;
            color: #c084fc;
            text-shadow: 0 0 10px rgba(147, 51, 234, 0.7);
            letter-spacing: 2px;
            text-transform: uppercase;
            border-bottom: 1px solid rgba(140, 60, 200, 0.4);
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .leaderboard-table {
            width: 100%;
            border-collapse: collapse;
        }

        .leaderboard-table th,
        .leaderboard-table td {
            padding: 12px 8px;
            text-align: center;
            border-bottom: 1px solid rgba(140, 60, 200, 0.2);
        }

        .table-scroll-wrapper {
            max-height: 420px;
            overflow-y: auto;
            border-radius: 10px;
            padding-right: 5px;
        }

        .table-scroll-wrapper::-webkit-scrollbar {
            width: 8px;
        }

        .table-scroll-wrapper::-webkit-scrollbar-track {
            background: rgba(40, 0, 70, 0.2);
            border-radius: 4px;
        }

        .table-scroll-wrapper::-webkit-scrollbar-thumb {
            background: rgba(140, 60, 200, 0.5);
            border-radius: 4px;
        }

        .table-scroll-wrapper::-webkit-scrollbar-thumb:hover {
            background: rgba(140, 60, 200, 0.8);
        }

        .leaderboard-table th {
            color: var(--color-gold);
            font-size: 1.1rem;
            text-transform: uppercase;
            border-bottom: 2px solid rgba(140, 60, 200, 0.4);
            position: sticky;
            top: 0;
            background: #1a0033;
            z-index: 10;
        }

        .leaderboard-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid rgba(140, 60, 200, 0.7);
            object-fit: cover;
            vertical-align: middle;
            margin-right: 10px;
        }

        .rank-number {
            font-weight: bold;
            color: #e9d5ff;
            font-size: 1.2rem;
        }

        .rank-gold {
            color: #ffd700;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.7);
            font-size: 1.5rem;
        }

        .rank-silver {
            color: #c0c0c0;
            text-shadow: 0 0 10px rgba(192, 192, 192, 0.7);
            font-size: 1.3rem;
        }

        .rank-bronze {
            color: #cd7f32;
            text-shadow: 0 0 10px rgba(205, 127, 50, 0.7);
            font-size: 1.3rem;
        }

        .lobby-action-btn {
            background: rgba(40, 0, 70, 0.35);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(140, 60, 200, 0.4);
            color: #e9d5ff;
            padding: 12px 0;
            border-radius: 20px;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
            text-align: center;
            flex: 1;
        }

        .lobby-action-btn:hover {
            background: rgba(140, 60, 200, 0.4);
            border-color: #c084fc;
            color: #fff;
            box-shadow: 0 0 15px rgba(140, 60, 200, 0.6), inset 0 0 10px rgba(140, 60, 200, 0.4);
            transform: translateY(-2px);
        }

        .lobby-action-btn:active {
            transform: translateY(0);
        }

        .friends-scroll-wrapper::-webkit-scrollbar {
            width: 6px;
        }

        .friends-scroll-wrapper::-webkit-scrollbar-track {
            background: rgba(40, 0, 70, 0.2);
            border-radius: 3px;
        }

        .friends-scroll-wrapper::-webkit-scrollbar-thumb {
            background: rgba(140, 60, 200, 0.4);
            border-radius: 3px;
        }

        .friends-scroll-wrapper::-webkit-scrollbar-thumb:hover {
            background: rgba(140, 60, 200, 0.7);
        }

        @keyframes lobby-pulse {
            0% {
                transform: scale(0.85);
                opacity: 0.5;
            }

            50% {
                transform: scale(1.15);
                opacity: 1;
            }

            100% {
                transform: scale(0.85);
                opacity: 0.5;
            }
        }

        @keyframes badgePulse {
            0% {
                transform: scale(1);
                box-shadow: 0 0 6px rgba(239, 68, 68, 0.6);
            }

            50% {
                transform: scale(1.15);
                box-shadow: 0 0 15px rgba(239, 68, 68, 1);
            }

            100% {
                transform: scale(1);
                box-shadow: 0 0 6px rgba(239, 68, 68, 0.6);
            }
        }
    </style>
</head>

<body style="background: url('/assets/background1.png') no-repeat center center fixed; background-size: cover;">
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="popup-notification-box" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(40, 10, 10, 0.95); border: 2px solid #ef4444; border-radius: 12px; padding: 15px 20px; min-width: 280px; max-width: 380px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 15px;">
                <h4 style="color: #ef4444; margin: 0; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold; display: flex; align-items: center; gap: 8px;">
                    <span>⚠️</span> Error
                </h4>
                <button onclick="this.parentElement.parentElement.remove()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0;">&times;</button>
            </div>
            <div style="color: #fee2e2; font-size: 1rem; font-weight: 500; margin-top: 5px;">
                <%= error %>
            </div>
        </div>
        <script>setTimeout(() => { const b = document.querySelector('.popup-notification-box'); if (b) b.remove(); }, 5000);</script>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="popup-notification-box" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(20, 40, 20, 0.95); border: 2px solid #4ade80; border-radius: 12px; padding: 15px 20px; min-width: 280px; max-width: 380px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 15px;">
                <h4 style="color: #4ade80; margin: 0; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold; display: flex; align-items: center; gap: 8px;">
                    <span>✓</span> Success
                </h4>
                <button onclick="this.parentElement.parentElement.remove()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0;">&times;</button>
            </div>
            <div style="color: #e8f5e9; font-size: 1rem; font-weight: 500; margin-top: 5px;">
                <%= success %>
            </div>
        </div>
        <script>setTimeout(() => { const b = document.querySelector('.popup-notification-box'); if (b) b.remove(); }, 5000);</script>
    <% } %>

    <canvas id="bg-particles" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>

    <button onclick="if(typeof playClickSound === 'function') playClickSound(); setTimeout(() => window.location.reload(), 150)" style="position: fixed; top: 25px; left: 25px; z-index: 1000; background: rgba(40, 0, 70, 0.6); border: 1px solid rgba(140, 60, 200, 0.4); color: #e9d5ff; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; backdrop-filter: blur(5px); box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);" onmouseover="this.style.background='rgba(140, 60, 200, 0.4)'; this.style.borderColor='#c084fc'; this.style.transform='rotate(180deg) scale(1.1)';" onmouseout="this.style.background='rgba(40, 0, 70, 0.6)'; this.style.borderColor='rgba(140, 60, 200, 0.4)'; this.style.transform='rotate(0deg) scale(1)';" title="Reload Page">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 2v6h-6"></path>
            <path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path>
            <path d="M3 22v-6h6"></path>
            <path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path>
        </svg>
    </button>

    <div class="container">
        <div class="lobby-content">
            <h1 class="dark-fantasy-title">Lobby</h1>

                            <div class="lobby-controls"
                                style="width: 100%; max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; gap: 40px; margin-top: 50px;">

                                <div class="top-panels"
                                    style="display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 40px; width: 100%;">
                                    <div class="user-section"
                                        style="display: flex; flex-direction: column; gap: 20px; flex: 1; min-width: 400px; height: 530px; box-sizing: border-box;">
                                        <div class="user-panel"
                                            style="justify-content: center; width: 100%; margin: 0; position: relative; padding-left: 40px; padding-right: 40px; box-sizing: border-box;">
                                            <!-- Coins moved to Armory -->
                                            <a href="/profile"
                                                style="display: block; border-radius: 50%; text-decoration: none;"
                                                title="View Profile">
                                                <img src="<%= typeof avatar !== 'undefined' ? avatar : '/assets/default_avatar.png' %>"
                                                    alt="Avatar" id="user-avatar"
                                                    style="transition: transform 0.3s, border-color 0.3s; cursor: pointer;"
                                                    onmouseover="this.style.transform='scale(1.05)'; this.style.borderColor='var(--color-gold)';"
                                                    onmouseout="this.style.transform='scale(1)'; this.style.borderColor='rgba(140, 60, 200, 0.7)';">
                                            </a>
                                            <div class="user-info">
                                                <h2>
                                                    <a href="/profile"
                                                        style="color: white; text-decoration: none; transition: color 0.3s;"
                                                        onmouseover="this.style.color='var(--color-gold)'"
                                                        onmouseout="this.style.color='white'" title="View Profile">
                                                        <%= nickname %>
                                                    </a>
                                                    <% const myRank=User.getRank(elo); %>
                                                        <div
                                                            style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                                                            <img src="/assets/ranks/<%= myRank.icon %>"
                                                                alt="<%= myRank.name %>" title="<%= myRank.name %>"
                                                                class="rank-icon-large"
                                                                style="width: 40px; height: 40px; border: none; box-shadow: none; border-radius: 0;">
                                                            <span id="user-elo-display"
                                                                style="color: var(--color-gold); font-size: 1.1rem; font-weight: bold;">
                                                                <%= elo %>
                                                            </span>
                                                        </div>
                                                </h2>
                                                <p>Ready for battle</p>
                                            </div>
                                            <a href="/auth/logout" class="logout-door-btn" title="Logout"
                                                style="position: absolute; bottom: 15px; right: 20px; color: rgba(255, 255, 255, 0.5); text-decoration: none; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: rgba(0,0,0,0.25); border: 1px solid rgba(140, 60, 200, 0.2);"
                                                onmouseover="this.style.color='#ef4444'; this.style.borderColor='rgba(239, 68, 68, 0.5)'; this.style.background='rgba(239, 68, 68, 0.15)'; this.style.transform='scale(1.1)';"
                                                onmouseout="this.style.color='rgba(255, 255, 255, 0.5)'; this.style.borderColor='rgba(140, 60, 200, 0.2)'; this.style.background='rgba(0,0,0,0.25)'; this.style.transform='scale(1)';">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                                    <polyline points="16 17 21 12 16 7"></polyline>
                                                    <line x1="21" y1="12" x2="9" y2="12"></line>
                                                </svg>
                                                <!--
                                                🚪
                                                -->
                                            </a>
                                        </div>
                                                                                                                        <div class="deck-shop-panel"
                                            style="position: relative; background: rgba(40, 0, 70, 0.35); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border: 1px solid rgba(140, 60, 200, 0.25); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8); border-radius: 27px; padding: 25px; width: 100%; flex: 1; min-height: 0; overflow: hidden; box-sizing: border-box; display: flex; flex-direction: column; gap: 15px; animation: fadeIn 0.8s ease-out; color: white;">
                                            <div style="position: absolute; top: 18px; right: 20px; display: flex; align-items: center; gap: 12px; z-index: 10;">
                                                <button type="button" id="open-achievements-btn" style="position: relative; overflow: visible; display: flex; align-items: center; justify-content: center; height: 38px; padding: 0 14px; gap: 8px; background: rgba(0,0,0,0.25); border-radius: 19px; border: 1px solid rgba(140, 60, 200, 0.2); text-decoration: none; color: rgba(255,255,255,0.6); font-weight: bold; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s ease; box-sizing: border-box; cursor: pointer; font-family: inherit; appearance: none;" onmouseover="this.style.background='rgba(140, 60, 200, 0.15)'; this.style.borderColor='rgba(140, 60, 200, 0.5)'; this.style.color='#fff'; this.style.transform='scale(1.05)';" onmouseout="this.style.background='rgba(0,0,0,0.25)'; this.style.borderColor='rgba(140, 60, 200, 0.2)'; this.style.color='rgba(255,255,255,0.6)'; this.style.transform='scale(1)';">
                                                    <span>ACHIEVEMENTS</span>
                                                    <span id="achievements-claim-badge" class="achievement-claim-badge" hidden>!</span>
                                                </button>
                                                <button type="button" id="open-shop-btn" style="display: flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; gap: 8px; background: rgba(0,0,0,0.25); border-radius: 19px; border: 1px solid rgba(140, 60, 200, 0.2); text-decoration: none; color: rgba(255,255,255,0.6); font-weight: bold; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s ease; box-sizing: border-box; cursor: pointer; font-family: inherit; appearance: none;" onmouseover="this.style.background='rgba(140, 60, 200, 0.15)'; this.style.borderColor='rgba(140, 60, 200, 0.5)'; this.style.color='#fff'; this.style.transform='scale(1.05)';" onmouseout="this.style.background='rgba(0,0,0,0.25)'; this.style.borderColor='rgba(140, 60, 200, 0.2)'; this.style.color='rgba(255,255,255,0.6)'; this.style.transform='scale(1)';">
                                                    <span>SHOP</span>
                                                </button>
                                                <div class="user-coins" style="display: flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; gap: 8px; background: rgba(0,0,0,0.25); border-radius: 19px; border: 1px solid rgba(140, 60, 200, 0.2); cursor: default; transition: all 0.3s ease; box-sizing: border-box;" onmouseover="this.style.background='rgba(140, 60, 200, 0.1)'; this.style.borderColor='rgba(140, 60, 200, 0.4)';" onmouseout="this.style.background='rgba(0,0,0,0.25)'; this.style.borderColor='rgba(140, 60, 200, 0.2)';">
                                                    <img src="/assets/coins.png" alt="Coins" style="width: 18px; height: 18px; border: none; opacity: 0.9; margin: 0;">
                                                    <span id="lobby-coin-amount" style="color: #ffd700; font-weight: bold; font-size: 1rem; margin-top: 1px;"><%= coins %></span>
                                                </div>
                                            </div>
                                            <h3 style="margin: 0; font-size: 1.5rem; letter-spacing: 1px; text-transform: uppercase; color: #c084fc; text-shadow: 0 0 10px rgba(147, 51, 234, 0.7); text-align: left; border-bottom: 1px solid rgba(140, 60, 200, 0.4); padding-bottom: 10px;">My Cards</h3>
                                            
                                            <div class="cards-scroll-wrapper" style="flex: 1; overflow-y: auto; padding-right: 5px; position: relative;">
                                                <style>
                                                    .cards-scroll-wrapper::-webkit-scrollbar { width: 6px; }
                                                    .cards-scroll-wrapper::-webkit-scrollbar-track { background: rgba(40, 0, 70, 0.2); border-radius: 3px; }
                                                    .cards-scroll-wrapper::-webkit-scrollbar-thumb { background: rgba(140, 60, 200, 0.4); border-radius: 3px; }
                                                    .cards-scroll-wrapper::-webkit-scrollbar-thumb:hover { background: rgba(140, 60, 200, 0.7); }
                                                    .armory-card {
                                                        background: rgba(0,0,0,0.4); border: 1px solid rgba(140, 60, 200, 0.5);
                                                        border-radius: 8px; padding: 8px; text-align: center;
                                                        display: flex; flex-direction: column; align-items: center; justify-content: space-between;
                                                        transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; height: 100%; box-sizing: border-box;
                                                    }
                                                    .armory-card:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(140, 60, 200, 0.4); border-color: #c084fc; }
                                                    .armory-card-locked {
                                                        background: rgba(0,0,0,0.2); border: 1px solid rgba(100, 100, 100, 0.3);
                                                        border-radius: 8px; padding: 8px; text-align: center;
                                                        display: flex; flex-direction: column; align-items: center; justify-content: space-between;
                                                        filter: grayscale(100%) opacity(0.5); transition: filter 0.3s; cursor: not-allowed; height: 100%; box-sizing: border-box;
                                                    }
                                                    .armory-card-locked:hover { filter: grayscale(80%) opacity(0.8); }
                                                    .armory-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(105px, 1fr)); gap: 10px; }
                                                    .armory-card img, .armory-card-locked img { width: 100%; height: auto; border-radius: 4px; margin-bottom: 5px; object-fit: contain; }
                                                </style>
                                                
                                                <% 
                                                   const unlockedCards = allCards.filter(c => userCardIds.includes(c.id));
                                                   const lockedCards = allCards.filter(c => !userCardIds.includes(c.id));
                                                %>
                                                
                                                <div id="owned-cards-grid" class="armory-grid">
                                                    <% unlockedCards.forEach(card => { %>
                                                        <div class="armory-card" data-card-id="<%= card.id %>" title="<%= card.name %> (Atk: <%= card.attack %> / Def: <%= card.defense %>)">
                                                            <img src="<%= card.image_url %>" alt="<%= card.name %>">
                                                            <div class="armory-card-name"><%= card.name %></div>
                                                            <div class="card-stats-line" aria-label="Card stats">
                                                                <span title="Damage">⚔️ <%= card.attack %></span>
                                                                <span title="HP">❤️ <%= card.defense %></span>
                                                                <span title="Energy">⚡ <%= card.cost %></span>
                                                            </div>
                                                        </div>
                                                    <% }) %>
                                                </div>
                                                
                                                <% if (lockedCards.length > 0) { %>
                                                    <div id="locked-cards-section">
                                                        <div style="margin: 20px 0 15px 0; border-top: 1px dashed rgba(140, 60, 200, 0.4); padding-top: 15px; text-align: center; color: rgba(255,255,255,0.4); text-transform: uppercase; font-size: 0.85rem; letter-spacing: 2px; font-weight: bold;">Locked Cards</div>
                                                        <div id="locked-cards-grid" class="armory-grid">
                                                            <% lockedCards.forEach(card => { %>
