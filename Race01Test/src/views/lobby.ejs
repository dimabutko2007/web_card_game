<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Realms - Lobby</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css?v=1.2">
    <style>
        .lobby-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
            margin-top: 50px;
        }

        .user-panel {
            background: rgba(40, 0, 70, 0.35);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(140, 60, 200, 0.25);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
            padding: 30px 60px;
            border-radius: 27px;
            display: flex;
            align-items: center;
            gap: 40px;
            animation: fadeIn 0.8s ease-out;
        }

        .user-panel img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 3px solid rgba(140, 60, 200, 0.7);
            box-shadow: 0 0 15px rgba(140, 60, 200, 0.5);
            object-fit: cover;
        }

        .user-info h2 {
            margin: 0;
            font-size: 2rem;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
        }

        .user-info p {
            color: rgba(255, 255, 255, 0.7);
            margin: 8px 0 0 0;
            font-size: 1.2rem;
        }

        .lobby-actions {
            display: flex;
            gap: 20px;
        }

        .match-btn {
            padding: 20px 60px;
            font-size: 1.5rem;
            width: 100%;
        }

        .match-btn.searching {
            background: var(--color-grey);
            cursor: not-allowed;
        }

        .nav-links {
            position: absolute;
            top: 20px;
            right: 20px;
            display: flex;
            gap: 20px;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 1.4rem;
            opacity: 0.8;
            transition: opacity 0.3s;
        }

        .nav-links a:hover {
            opacity: 1;
            color: var(--color-gold);
        }

        #status-msg {
            margin-top: 20px;
            font-style: italic;
            color: var(--color-gold);
            height: 24px;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
                color: var(--color-gold);
            }

            50% {
                transform: scale(1.2);
                color: #fff;
                text-shadow: 0 0 10px var(--color-gold);
            }

            100% {
                transform: scale(1);
                color: var(--color-gold);
            }
        }

        .leaderboard-panel {
            background: rgba(40, 0, 70, 0.35);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(140, 60, 200, 0.25);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
            padding: 30px;
            border-radius: 27px;
            animation: fadeIn 0.8s ease-out;
            color: white;
        }

        .leaderboard-panel h3 {
            margin-top: 0;
            text-align: center;
            font-size: 2rem;
            color: #c084fc;
            text-shadow: 0 0 10px rgba(147, 51, 234, 0.7);
            letter-spacing: 2px;
            text-transform: uppercase;
            border-bottom: 1px solid rgba(140, 60, 200, 0.4);
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .leaderboard-table {
            width: 100%;
            border-collapse: collapse;
        }

        .leaderboard-table th,
        .leaderboard-table td {
            padding: 12px 8px;
            text-align: center;
            border-bottom: 1px solid rgba(140, 60, 200, 0.2);
        }

        .table-scroll-wrapper {
            max-height: 400px;
            overflow-y: auto;
            border-radius: 10px;
            padding-right: 5px;
        }

        .table-scroll-wrapper::-webkit-scrollbar {
            width: 8px;
        }

        .table-scroll-wrapper::-webkit-scrollbar-track {
            background: rgba(40, 0, 70, 0.2);
            border-radius: 4px;
        }

        .table-scroll-wrapper::-webkit-scrollbar-thumb {
            background: rgba(140, 60, 200, 0.5);
            border-radius: 4px;
        }

        .table-scroll-wrapper::-webkit-scrollbar-thumb:hover {
            background: rgba(140, 60, 200, 0.8);
        }

        .leaderboard-table th {
            color: var(--color-gold);
            font-size: 1.1rem;
            text-transform: uppercase;
            border-bottom: 2px solid rgba(140, 60, 200, 0.4);
            position: sticky;
            top: 0;
            background: #1a0033;
            z-index: 10;
        }

        .leaderboard-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid rgba(140, 60, 200, 0.7);
            object-fit: cover;
            vertical-align: middle;
            margin-right: 10px;
        }

        .rank-number {
            font-weight: bold;
            color: #e9d5ff;
            font-size: 1.2rem;
        }

        .rank-gold {
            color: #ffd700;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.7);
            font-size: 1.5rem;
        }

        .rank-silver {
            color: #c0c0c0;
            text-shadow: 0 0 10px rgba(192, 192, 192, 0.7);
            font-size: 1.3rem;
        }

        .rank-bronze {
            color: #cd7f32;
            text-shadow: 0 0 10px rgba(205, 127, 50, 0.7);
            font-size: 1.3rem;
        }

        .lobby-action-btn {
            background: rgba(40, 0, 70, 0.35);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(140, 60, 200, 0.4);
            color: #e9d5ff;
            padding: 12px 0;
            border-radius: 20px;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
            text-align: center;
            flex: 1;
        }

        .lobby-action-btn:hover {
            background: rgba(140, 60, 200, 0.4);
            border-color: #c084fc;
            color: #fff;
            box-shadow: 0 0 15px rgba(140, 60, 200, 0.6), inset 0 0 10px rgba(140, 60, 200, 0.4);
            transform: translateY(-2px);
        }

        .lobby-action-btn:active {
            transform: translateY(0);
        }
    </style>
</head>

<body style="background: url('/assets/background1.png') no-repeat center center fixed; background-size: cover;">
    <canvas id="bg-particles"
        style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>

    <div class="container">
        <div class="lobby-content">
            <h1 class="dark-fantasy-title">Lobby</h1>

            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert-error"
                    style="color: #ff5a5a; background: rgba(226, 54, 54, 0.15); border: 1px solid rgba(226, 54, 54, 0.3); padding: 10px 20px; border-radius: 10px; margin-bottom: 15px; font-weight: bold; width: 100%; max-width: 600px; text-align: center;">
                    <%= error %>
                </div>
                <% } %>
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="alert-success"
                            style="color: #4ade80; background: rgba(240, 165, 0, 0.15); border: 1px solid rgba(240, 165, 0, 0.3); padding: 10px 20px; border-radius: 10px; margin-bottom: 15px; font-weight: bold; width: 100%; max-width: 600px; text-align: center;">
                            <%= success %>
                        </div>
                        <% } %>

                            <div class="lobby-controls"
                                style="width: 100%; max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; gap: 40px; margin-top: 50px;">

                                <div class="top-panels"
                                    style="display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 40px; width: 100%;">
                                    <div class="user-section"
                                        style="display: flex; flex-direction: column; gap: 20px; flex: 1; min-width: 400px;">
                                        <div class="user-panel"
                                            style="justify-content: center; width: 100%; margin: 0;">
                                            <img src="<%= typeof avatar !== 'undefined' ? avatar : '/assets/default_avatar.png' %>"
                                                alt="Avatar" id="user-avatar">
                                            <div class="user-info">
                                                <h2>
                                                    <%= nickname %>
                                                        <% const myRank=User.getRank(elo); %>
                                                            <div
                                                                style="display: flex; align-items: center; gap: 10px; margin-top: 5px;">
                                                                <img src="/assets/ranks/<%= myRank.icon %>"
                                                                    alt="<%= myRank.name %>" title="<%= myRank.name %>"
                                                                    class="rank-icon-large"
                                                                    style="width: 40px; height: 40px; border: none; box-shadow: none; border-radius: 0;">
                                                                <span id="user-elo-display"
                                                                    style="color: var(--color-gold); font-size: 1.1rem; font-weight: bold;">
                                                                    <%= elo %>
                                                                </span>
                                                            </div>
                                                </h2>
                                                <p>Ready for battle</p>
                                            </div>
                                        </div>
                                        <div class="user-actions"
                                            style="display: flex; gap: 20px; justify-content: center; width: 100%;">
                                            <a href="/profile" class="lobby-action-btn">Profile</a>
                                            <a href="/auth/logout" class="lobby-action-btn">Logout</a>
                                        </div>
                                    </div>

                                    <div class="leaderboard-panel" style="flex: 1; min-width: 400px;">
                                        <h3>Top Players</h3>
                                        <div class="table-scroll-wrapper">
                                            <table class="leaderboard-table">
                                                <thead>
                                                    <tr>
                                                        <th>Rank</th>
                                                        <th>Player</th>
                                                        <th>Division</th>
                                                        <th>Elo</th>
                                                        <th>Win %</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (typeof leaders !=='undefined' && leaders.length> 0) { %>
                                                        <% leaders.forEach((leader, index)=> {
                                                            const totalGames = leader.wins + leader.losses;
                                                            const winRate = totalGames > 0 ? Math.round((leader.wins /
                                                            totalGames) *
                                                            100) : 0;
                                                            %>
                                                            <tr>
                                                                <td>
                                                                    <% let rankClass='' ; if (index===0)
                                                                        rankClass='rank-gold' ; else if (index===1)
                                                                        rankClass='rank-silver' ; else if (index===2)
                                                                        rankClass='rank-bronze' ; %>
                                                                        <span class="rank-number <%= rankClass %>">
                                                                            #<%= index + 1 %>
                                                                        </span>
                                                                </td>
                                                                <td style="text-align: left;">
                                                                    <a href="/profile/<%= leader.nickname %>"
                                                                        style="color: white; text-decoration: none; display: flex; align-items: center;">
                                                                        <img src="<%= leader.avatar || '/assets/default_avatar.png' %>"
                                                                            class="leaderboard-avatar" alt="Avatar">
                                                                        <%= leader.nickname %>
                                                                    </a>
                                                                </td>
                                                                <td>
                                                                    <% const leaderRank=User.getRank(leader.elo); %>
                                                                        <img src="/assets/ranks/<%= leaderRank.icon %>"
                                                                            alt="<%= leaderRank.name %>"
                                                                            title="<%= leaderRank.name %>"
                                                                            class="rank-icon-large"
                                                                            style="width: 35px; height: 35px; border-radius: 0; display: block; margin: 0 auto;">
                                                                </td>
                                                                <td
                                                                    style="color: var(--color-gold); font-weight: bold;">
                                                                    <%= leader.elo %>
                                                                </td>
                                                                <td style="color: #e9d5ff;">
                                                                    <%= winRate %>%
                                                                </td>
                                                            </tr>
                                                            <% }) %>
                                                                <% } else { %>
                                                                    <tr>
                                                                        <td colspan="4"
                                                                            style="text-align: center; padding: 20px; color: rgba(255,255,255,0.5);">
                                                                            No leaders yet</td>
                                                                    </tr>
                                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <div class="bottom-actions"
                                    style="width: 100%; display: flex; flex-direction: column; align-items: center; margin-top: 40px;">
                                    <div id="lobby-stats"
                                        style="margin-bottom: 20px; font-size: 1.2rem; color: #e9d5ff; text-shadow: 0 0 10px rgba(147, 51, 234, 0.5); background: rgba(40, 0, 70, 0.4); padding: 10px 20px; border-radius: 15px; border: 1px solid rgba(140, 60, 200, 0.3);">
                                        <span style="margin-right: 15px;">🟢 Online: <span
                                                id="stat-online">1</span></span>
                                        <span>🔍 Searching: <span id="stat-searching">0</span></span>
                                    </div>
                                    <button id="find-match-btn" class="btn match-btn">Search Battle</button>
                                    <div id="status-msg" style="margin-top: 20px;"></div>
                                </div>

                            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const findMatchBtn = document.getElementById('find-match-btn');
        const statusMsg = document.getElementById('status-msg');
        let hasActiveGame = false;

        // Join personal room for notifications
        socket.emit('joinUserRoom', { userId: '<%= userId %>' });

        // Check for active game on load
        socket.emit('checkActiveGame', { userId: '<%= userId %>' });

        socket.on('lobbyStatsUpdate', (data) => {
            const statOnline = document.getElementById('stat-online');
            const statSearching = document.getElementById('stat-searching');
            if (statOnline) statOnline.textContent = data.online;
            if (statSearching) statSearching.textContent = data.searching;
        });

        socket.on('activeGameFound', (data) => {
            hasActiveGame = true;
            findMatchBtn.textContent = 'Return to Battle';
            findMatchBtn.classList.add('active-game-button');
            statusMsg.textContent = 'You have an active battle!';
        });

        socket.on('activeGameEnded', () => {
            hasActiveGame = false;
            findMatchBtn.textContent = 'Search Battle';
            findMatchBtn.classList.remove('active-game-button');
            statusMsg.textContent = 'Previous battle has ended.';
        });

        socket.on('statsUpdate', (data) => {
            const eloDisplay = document.getElementById('user-elo-display');
            if (eloDisplay) {
                eloDisplay.textContent = `(Elo: ${data.elo})`;
                eloDisplay.style.animation = 'pulse 1s ease-in-out';
                setTimeout(() => eloDisplay.style.animation = '', 1000);
            }
        });

        findMatchBtn.addEventListener('click', () => {
            if (findMatchBtn.classList.contains('searching')) return;

            findMatchBtn.classList.add('searching');
            findMatchBtn.textContent = 'Searching...';
            statusMsg.textContent = 'Waiting for opponent...';

            socket.emit('findMatch', {
                nickname: '<%= nickname %>',
                userId: '<%= userId %>',
                avatar: '<%= typeof avatar !== "undefined" ? avatar : "/assets/default_avatar.png" %>',
                elo: '<%= elo %>'
            });
        });

        socket.on('matchFound', (data) => {
            statusMsg.textContent = 'Opponent found! Entering battle...';
            if (typeof playMatchStartSound === 'function') playMatchStartSound();
            setTimeout(() => {
                window.location.href = `/game/${data.gameId}`;
            }, 2000);
        });

        // Clear query parameters from URL after load so they don't persist on reload
        window.addEventListener('load', () => {
            if (window.location.search.includes('error=') || window.location.search.includes('success=')) {
                const url = new URL(window.location);
                url.searchParams.delete('error');
                url.searchParams.delete('success');
                window.history.replaceState({}, document.title, url.pathname + url.search);
            }
        });

        // Listen for real-time friend requests
        socket.on('friendRequestReceived', (data) => {
            // Check if toast already exists
            const existing = document.getElementById('friend-request-notification-box');
            if (existing) {
                existing.remove();
            }

            const toast = document.createElement('div');
            toast.id = 'friend-request-notification-box';
            toast.style.cssText = "position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(26, 0, 51, 0.95); border: 2px solid #a78bfa; border-radius: 12px; padding: 15px 20px; max-width: 350px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif;";

            toast.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; gap: 15px;">
                    <h4 style="color: #e9d5ff; margin: 0; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">New Friend Request</h4>
                    <button onclick="document.getElementById('friend-request-notification-box').remove()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">&times;</button>
                </div>
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
                    <img src="${data.avatar}" alt="Avatar" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid #e9d5ff;">
                    <div>
                        <a href="/profile/${data.nickname}" style="color: #e9d5ff; text-decoration: none; font-weight: bold; font-size: 1rem; display: block; transition: color 0.2s;" onmouseover="this.style.color='#a78bfa'" onmouseout="this.style.color='#e9d5ff'">${data.nickname}</a>
                        <span style="color: #aaa; font-size: 0.8rem; display: block; margin-top: 2px;">wants to be your friend!</span>
                    </div>
                </div>
                <div style="display: flex; gap: 10px;">
                    <form action="/profile/${data.nickname}/accept-friend" method="POST" style="flex: 1; margin: 0;">
                        <button type="submit" style="width: 100%; background: linear-gradient(45deg, #4ade80, #15803d); color: white; border: none; padding: 8px 12px; border-radius: 6px; font-weight: bold; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">Accept</button>
                    </form>
                    <form action="/profile/${data.nickname}/decline-friend" method="POST" style="flex: 1; margin: 0;">
                        <button type="submit" style="width: 100%; background: rgba(255,255,255,0.08); color: #ccc; border: 1px solid rgba(255,255,255,0.15); padding: 8px 12px; border-radius: 6px; font-weight: bold; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; transition: background 0.2s, color 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)'; this.style.color='#fff'" onmouseout="this.style.background='rgba(255,255,255,0.08)'; this.style.color='#ccc'">Decline</button>
                    </form>
                </div>
            `;
            document.body.appendChild(toast);
        });
    </script>
    <script src="/js/particles.js"></script>
    <style>
        @keyframes slideInUp {
            from {
                transform: translateY(100px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
    </style>
    <script src="/js/volume-controls.js"></script>
    <script src="/js/sounds.js"></script>
</body>

</html>