<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Great Battle - Lobby</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .lobby-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
            margin-top: 50px;
        }

        .user-panel {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            padding: 20px 40px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            animation: fadeIn 0.8s ease-out;
        }

        .user-panel img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            border: 2px solid var(--marvel-red);
            object-fit: cover;
        }

        .user-info h2 {
            margin: 0;
            font-size: 1.5rem;
        }

        .user-info p {
            color: rgba(255, 255, 255, 0.6);
            margin: 0;
        }

        .lobby-actions {
            display: flex;
            gap: 20px;
        }

        .match-btn {
            padding: 20px 60px;
            font-size: 1.5rem;
            background: linear-gradient(45deg, var(--marvel-red), #ff5a5a);
            box-shadow: 0 0 20px rgba(226, 54, 54, 0.4);
        }

        .match-btn.searching {
            background: var(--marvel-grey);
            cursor: not-allowed;
        }

        .nav-links {
            position: absolute;
            top: 20px;
            right: 20px;
            display: flex;
            gap: 20px;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 0.9rem;
            opacity: 0.8;
            transition: opacity 0.3s;
        }

        .nav-links a:hover {
            opacity: 1;
            color: var(--marvel-gold);
        }

        #status-msg {
            margin-top: 20px;
            font-style: italic;
            color: var(--marvel-gold);
            height: 24px;
        }

        @keyframes pulse {
            0% { transform: scale(1); color: var(--marvel-gold); }
            50% { transform: scale(1.2); color: #fff; text-shadow: 0 0 10px var(--marvel-gold); }
            100% { transform: scale(1); color: var(--marvel-gold); }
        }
    </style>
</head>

<body>
    <div class="nav-links">
        <a href="/profile">Profile</a>
        <a href="/auth/logout">Logout</a>
    </div>

    <div class="container">
        <div class="lobby-content">
            <h1 style="font-size: 3rem; text-transform: uppercase; letter-spacing: 5px;">Lobby</h1>

            <div class="user-panel">
                <img src="<%= typeof avatar !== 'undefined' ? avatar : '/assets/default_avatar.png' %>" alt="Avatar" id="user-avatar">
                <div class="user-info">
                    <h2>
                        <%= nickname %> <span id="user-elo-display" style="color: var(--marvel-gold); font-size: 1rem; margin-left: 10px;">(Elo: <%= elo %>)</span>
                    </h2>
                    <p>Ready for battle</p>
                </div>
            </div>

            <button id="find-match-btn" class="btn match-btn">Search Battle</button>
            <div id="status-msg"></div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const findMatchBtn = document.getElementById('find-match-btn');
        const statusMsg = document.getElementById('status-msg');
        let hasActiveGame = false;

        // Join personal room for notifications
        socket.emit('joinUserRoom', { userId: '<%= userId %>' });

        // Check for active game on load
        socket.emit('checkActiveGame', { userId: '<%= userId %>' });

        socket.on('activeGameFound', (data) => {
            hasActiveGame = true;
            findMatchBtn.textContent = 'Return to Battle';
            findMatchBtn.classList.add('active-game-button');
            statusMsg.textContent = 'You have an active battle!';
        });

        socket.on('activeGameEnded', () => {
            hasActiveGame = false;
            findMatchBtn.textContent = 'Search Battle';
            findMatchBtn.classList.remove('active-game-button');
            statusMsg.textContent = 'Previous battle has ended.';
        });

        socket.on('statsUpdate', (data) => {
            const eloDisplay = document.getElementById('user-elo-display');
            if (eloDisplay) {
                eloDisplay.textContent = `(Elo: ${data.elo})`;
                eloDisplay.style.animation = 'pulse 1s ease-in-out';
                setTimeout(() => eloDisplay.style.animation = '', 1000);
            }
        });

        findMatchBtn.addEventListener('click', () => {
            if (findMatchBtn.classList.contains('searching')) return;

            findMatchBtn.classList.add('searching');
            findMatchBtn.textContent = 'Searching...';
            statusMsg.textContent = 'Waiting for opponent...';

            socket.emit('findMatch', { 
                nickname: '<%= nickname %>', 
                userId: '<%= userId %>',
                avatar: '<%= typeof avatar !== "undefined" ? avatar : "/assets/default_avatar.png" %>',
                elo: '<%= elo %>'
            });
        });

        socket.on('matchFound', (data) => {
            statusMsg.textContent = 'Opponent found! Entering battle...';
            setTimeout(() => {
                window.location.href = `/game/${data.gameId}`;
            }, 2000);
        });
    </script>
</body>

</html>