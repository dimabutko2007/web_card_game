                    <%- include('shop') %>

                    <% const achievementPayload = {
                        achievements: typeof achievements !== 'undefined' ? achievements : [],
                        recentUnlocks: typeof recentAchievementUnlocks !== 'undefined' ? recentAchievementUnlocks : []
                    }; %>

                    <div id="achievement-toast-root" class="achievement-toast-root" aria-live="polite"></div>

                    <div id="achievements-modal" class="achievements-modal" aria-hidden="true">
                        <div class="achievements-backdrop" data-achievements-close></div>
                        <section class="achievements-window" role="dialog" aria-modal="true" aria-labelledby="achievements-title">
                            <div class="achievements-header">
                                <div>
                                    <h2 id="achievements-title">Achievements</h2>
                                    <div class="achievements-summary">
                                        <span id="achievements-unlocked-count">0</span>
                                        <span>/</span>
                                        <span id="achievements-total-count">0</span>
                                        <span>unlocked</span>
                                    </div>
                                </div>
                                <button type="button" id="achievements-close-btn" class="achievements-close-btn" aria-label="Close achievements">&times;</button>
                            </div>
                            <div id="achievements-category-tabs" class="achievements-category-tabs" aria-label="Achievement categories"></div>
                            <div id="achievements-list" class="achievements-content achievements-list"></div>
                        </section>
                    </div>

                    <script type="application/json" id="achievements-bootstrap"><%- JSON.stringify(achievementPayload).replace(/</g, '\\u003c') %></script>

    <div id="lobby-player-data" data-player="<%= JSON.stringify({ userId: String(userId), nickname: nickname, avatar: typeof avatar !== 'undefined' ? avatar : '/assets/default_avatar.png', elo: elo }) %>" style="display: none;"></div>

                    <script src="/socket.io/socket.io.js"></script>
                    <script>
                        const socket = io();
                        window.lobbySocket = socket;
                        const findMatchBtn = document.getElementById('find-match-btn');
                        const statusMsg = document.getElementById('status-msg');
                        let hasActiveGame = false;
                        let activeGameId = null;
                        const lobbyPlayer = JSON.parse(document.getElementById('lobby-player-data').dataset.player);
                        const pendingBattleInviteTargets = new Map();

        socket.emit('joinUserRoom', { userId: '<%= userId %>' });
        socket.emit('checkActiveGame', { userId: '<%= userId %>' });

        socket.on('lobbyStatsUpdate', (data) => {
            const statOnline = document.getElementById('stat-online');
            const statSearching = document.getElementById('stat-searching');
            if (statOnline) statOnline.textContent = data.online;
            if (statSearching) statSearching.textContent = data.searching;
        });

        socket.on('activeGameFound', (data) => {
            hasActiveGame = true;
            activeGameId = data.gameId;
            findMatchBtn.textContent = 'Return to Battle';
            findMatchBtn.classList.add('active-game-button');
            statusMsg.textContent = 'You have an active battle!';
            refreshBattleInviteButtons();
        });

        socket.on('activeGameEnded', () => {
            hasActiveGame = false;
            activeGameId = null;
            findMatchBtn.textContent = 'Search Battle';
            findMatchBtn.classList.remove('active-game-button');
            statusMsg.textContent = 'Previous battle has ended.';
            refreshBattleInviteButtons();
        });

                        socket.on('statsUpdate', (data) => {
                            const eloDisplay = document.getElementById('user-elo-display');
                            if (eloDisplay) {
                                eloDisplay.textContent = `(Elo: ${data.elo})`;
                                eloDisplay.style.animation = 'pulse 1s ease-in-out';
                                setTimeout(() => eloDisplay.style.animation = '', 1000);
                            }
                            if (typeof data.coins !== 'undefined') {
                                if (window.Achievements && typeof window.Achievements.updateCoins === 'function') {
                                    window.Achievements.updateCoins(data.coins);
                                } else {
                                    document.querySelectorAll('#lobby-coin-amount, #shop-coin-amount').forEach((coinAmount) => {
                                        coinAmount.textContent = data.coins;
                                    });
                                }
                            }
                        });

        findMatchBtn.addEventListener('click', () => {
            if (hasActiveGame && activeGameId) {
                window.location.href = `/game/${activeGameId}`;
                return;
            }
            if (findMatchBtn.classList.contains('searching')) {
                socket.emit('cancelSearch');
                findMatchBtn.classList.remove('searching');
                findMatchBtn.textContent = 'Search Battle';
                statusMsg.textContent = 'Search cancelled.';
                refreshBattleInviteButtons();
                return;
            }
            clearAllBattleInviteButtons();
            findMatchBtn.classList.add('searching');
            findMatchBtn.textContent = 'Searching...';
            statusMsg.textContent = 'Waiting for opponent...';
            refreshBattleInviteButtons();
            socket.emit('findMatch', {
                nickname: '<%= nickname %>',
                userId: '<%= userId %>',
                avatar: '<%= typeof avatar !== "undefined" ? avatar : "/assets/default_avatar.png" %>',
                elo: '<%= elo %>'
            });
        });

        socket.on('matchFound', (data) => {
            statusMsg.textContent = 'Opponent found! Entering battle...';
            if (typeof playMatchStartSound === 'function') playMatchStartSound();
            setTimeout(() => { window.location.href = `/game/${data.gameId}`; }, 2000);
        });

        socket.on('matchSearchError', (data) => {
            findMatchBtn.classList.remove('searching');
            findMatchBtn.textContent = 'Search Battle';
            statusMsg.textContent = data.message || 'Could not start battle search.';
            refreshBattleInviteButtons();
        });

        function escapeHtml(value) {
            const chars = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return String(value || '').replace(/[&<>"']/g, char => chars[char]);
        }

        function isSearchingBattle() { return findMatchBtn.classList.contains('searching'); }
        function getBattleInviteButton(friendId) { return document.querySelector(`.battle-invite-btn[data-friend-id="${friendId}"]`); }

        function setBattleInviteButtonState(friendId, state) {
            const button = getBattleInviteButton(friendId);
            if (!button) return;
            if (!button.dataset.originalLabel) { button.dataset.originalLabel = button.innerHTML.trim(); }
            if (state === 'sent') {
                button.disabled = true;
                button.classList.add('is-sent');
                button.textContent = 'Sent';
                button.title = 'Battle invite sent';
                return;
            }
            pendingBattleInviteTargets.delete(String(friendId));
            button.classList.remove('is-sent');
            button.innerHTML = button.dataset.originalLabel || '&#9876;';
            const canInvite = button.dataset.canInvite === 'true';
            button.disabled = !canInvite || hasActiveGame || isSearchingBattle();
            button.title = canInvite ? 'Invite to battle' : button.title;
        }

        function refreshBattleInviteButtons() {
            document.querySelectorAll('.battle-invite-btn').forEach(button => {
                const friendId = button.dataset.friendId;
                if (pendingBattleInviteTargets.has(String(friendId))) {
                    button.disabled = true;
                    return;
                }
                const canInvite = button.dataset.canInvite === 'true';
                button.disabled = !canInvite || hasActiveGame || isSearchingBattle();
            });
        }

        function clearAllBattleInviteButtons() {
            [...pendingBattleInviteTargets.keys()].forEach(friendId => setBattleInviteButtonState(friendId, 'idle'));
            pendingBattleInviteTargets.clear();
            refreshBattleInviteButtons();
        }

        function showBattleNotice(message, type = 'info') {
            const existing = document.getElementById('battle-invite-status-box');
            if (existing) existing.remove();
            const toast = document.createElement('div');
            toast.id = 'battle-invite-status-box';
            const border = type === 'error' ? '#ef4444' : (type === 'success' ? '#4ade80' : '#a78bfa');
            const titleColor = type === 'error' ? '#fecaca' : (type === 'success' ? '#bbf7d0' : '#e9d5ff');
            toast.style.cssText = `position: fixed; bottom: 20px; left: 20px; z-index: 9999; background: rgba(26, 0, 51, 0.95); border: 2px solid ${border}; border-radius: 12px; padding: 14px 18px; max-width: 340px; box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 18px rgba(168,85,247,0.22); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif;`;
            toast.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 15px;">
                    <div>
                        <h4 style="color: ${titleColor}; margin: 0 0 6px 0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">Battle Invite</h4>
                        <div style="color: #ddd6fe; font-size: 0.92rem; line-height: 1.35;">${escapeHtml(message)}</div>
                    </div>
                    <button type="button" aria-label="Close" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.35rem; line-height: 1; padding: 0;">&times;</button>
                </div>
            `;
            toast.querySelector('button').addEventListener('click', () => toast.remove());
            document.body.appendChild(toast);
            setTimeout(() => { if (toast.isConnected) toast.remove(); }, 4500);
        }

        function closeBattleInvitePopup(inviteId) {
            const popup = document.getElementById(`battle-invite-${inviteId}`);
            if (popup) popup.remove();
        }

        function showBattleInvitePopup(data) {
            closeBattleInvitePopup(data.inviteId);
            const sender = data.sender || {};
            const toast = document.createElement('div');
            toast.id = `battle-invite-${data.inviteId}`;
            toast.style.cssText = "position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(26, 0, 51, 0.96); border: 2px solid #c084fc; border-radius: 12px; padding: 15px 20px; width: min(350px, calc(100vw - 40px)); box-sizing: border-box; box-shadow: 0 10px 30px rgba(0,0,0,0.55), 0 0 22px rgba(168,85,247,0.32); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif;";
            toast.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; gap: 15px;">
                    <h4 style="color: #e9d5ff; margin: 0; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">Battle Invite</h4>
                    <button type="button" class="battle-invite-close" aria-label="Close" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0; transition: color 0.2s;">&times;</button>
                </div>
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
                    <img src="${escapeHtml(sender.avatar || '/assets/default_avatar.png')}" alt="Avatar" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid #e9d5ff; box-shadow: 0 0 12px rgba(192,132,252,0.38);">
                    <div style="min-width: 0;">
                        <a href="/profile/${encodeURIComponent(sender.nickname || '')}" style="color: #e9d5ff; text-decoration: none; font-weight: bold; font-size: 1rem; display: block; transition: color 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${escapeHtml(sender.nickname)}</a>
                        <span style="color: #c4b5fd; font-size: 0.82rem; display: block; margin-top: 2px;">${escapeHtml(sender.nickname)} invites you to battle</span>
                    </div>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="button" class="battle-toast-action battle-toast-accept" data-action="accept">Accept</button>
                    <button type="button" class="battle-toast-action battle-toast-decline" data-action="decline">Decline</button>
                </div>
            `;
            toast.querySelector('.battle-invite-close').addEventListener('click', () => {
                socket.emit('declineBattleInvite', { inviteId: data.inviteId });
                toast.remove();
            });
            toast.querySelector('[data-action="accept"]').addEventListener('click', () => {
                toast.querySelectorAll('button').forEach(button => button.disabled = true);
                statusMsg.textContent = 'Accepting battle invite...';
                socket.emit('acceptBattleInvite', { inviteId: data.inviteId });
            });
            toast.querySelector('[data-action="decline"]').addEventListener('click', () => {
                toast.querySelectorAll('button').forEach(button => button.disabled = true);
                socket.emit('declineBattleInvite', { inviteId: data.inviteId });
                toast.remove();
            });
            document.body.appendChild(toast);
        }

        document.querySelectorAll('.battle-invite-btn').forEach(button => {
            button.addEventListener('click', () => {
                if (button.disabled) return;
                const friendId = button.dataset.friendId;
                const friendNickname = button.dataset.friendNickname || 'friend';
                pendingBattleInviteTargets.set(String(friendId), true);
                setBattleInviteButtonState(friendId, 'sent');
                statusMsg.textContent = `Battle invite sent to ${friendNickname}...`;
                socket.emit('sendBattleInvite', {
                    targetUserId: friendId,
                    userId: lobbyPlayer.userId,
                    nickname: lobbyPlayer.nickname,
                    avatar: lobbyPlayer.avatar,
                    elo: lobbyPlayer.elo
                });
            });
        });

        socket.on('battleInviteSent', (data) => {
            pendingBattleInviteTargets.set(String(data.targetUserId), true);
            setBattleInviteButtonState(data.targetUserId, 'sent');
            showBattleNotice(`Battle invite sent to ${data.targetNickname}.`, 'success');
        });

        socket.on('battleInviteError', (data) => {
            if (data && data.targetUserId) { setBattleInviteButtonState(data.targetUserId, 'idle'); }
            showBattleNotice(data.message || 'Failed to send battle invite.', 'error');
            statusMsg.textContent = data.message || 'Failed to send battle invite.';
        });

        socket.on('battleInviteReceived', (data) => {
            if (hasActiveGame || isSearchingBattle()) {
                socket.emit('declineBattleInvite', { inviteId: data.inviteId });
                return;
            }
            showBattleInvitePopup(data);
        });

        socket.on('battleInviteAccepted', (data) => {
            statusMsg.textContent = `Battle invite accepted! Entering battle against ${data.opponentNickname}...`;
        });

        socket.on('battleInviteDeclined', (data) => {
            if (data && data.targetUserId) { setBattleInviteButtonState(data.targetUserId, 'idle'); }
            showBattleNotice(data.message || 'Battle invite declined.', 'info');
            statusMsg.textContent = data.message || 'Battle invite declined.';
        });

        socket.on('battleInviteExpired', (data) => {
            if (data && data.targetUserId) { setBattleInviteButtonState(data.targetUserId, 'idle'); }
            if (data && data.inviteId) { closeBattleInvitePopup(data.inviteId); }
            if (data && data.message) { showBattleNotice(data.message, 'info'); }
        });

        socket.on('battleInviteClosed', (data) => {
            if (data && data.inviteId) { closeBattleInvitePopup(data.inviteId); }
        });

        socket.on('battleInviteUnavailable', (data) => {
            if (data && data.targetUserId) { setBattleInviteButtonState(data.targetUserId, 'idle'); }
            if (data && data.inviteId) { closeBattleInvitePopup(data.inviteId); }
            showBattleNotice(data.message || 'Battle invite is no longer available.', 'error');
            statusMsg.textContent = data.message || 'Battle invite is no longer available.';
        });

        window.addEventListener('load', () => {
            if (window.location.search.includes('error=') || window.location.search.includes('success=')) {
                const url = new URL(window.location);
                url.searchParams.delete('error');
                url.searchParams.delete('success');
                window.history.replaceState({}, document.title, url.pathname + url.search);
            }
        });

        socket.on('friendRequestReceived', (data) => {
            const existing = document.getElementById('friend-request-notification-box');
            if (existing) existing.remove();
            const toast = document.createElement('div');
            toast.id = 'friend-request-notification-box';
            toast.style.cssText = "position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(26, 0, 51, 0.95); border: 2px solid #a78bfa; border-radius: 12px; padding: 15px 20px; max-width: 350px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif;";
            toast.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; gap: 15px;">
                    <h4 style="color: #e9d5ff; margin: 0; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">New Friend Request</h4>
                    <button onclick="document.getElementById('friend-request-notification-box').remove()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">&times;</button>
                </div>
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
                    <img src="${data.avatar}" alt="Avatar" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid #e9d5ff;">
                    <div>
                        <a href="/profile/${data.nickname}" style="color: #e9d5ff; text-decoration: none; font-weight: bold; font-size: 1rem; display: block; transition: color 0.2s;" onmouseover="this.style.color='#a78bfa'" onmouseout="this.style.color='#e9d5ff'">${data.nickname}</a>
                        <span style="color: #aaa; font-size: 0.8rem; display: block; margin-top: 2px;">wants to be your friend!</span>
                    </div>
                </div>
                <div style="display: flex; gap: 10px;">
                    <form action="/profile/${data.nickname}/accept-friend" method="POST" style="flex: 1; margin: 0;">
                        <button type="submit" style="width: 100%; background: linear-gradient(45deg, #4ade80, #15803d); color: white; border: none; padding: 8px 12px; border-radius: 6px; font-weight: bold; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">Accept</button>
                    </form>
                    <form action="/profile/${data.nickname}/decline-friend" method="POST" style="flex: 1; margin: 0;">
                        <button type="submit" style="width: 100%; background: rgba(255,255,255,0.08); color: #ccc; border: 1px solid rgba(255,255,255,0.15); padding: 8px 12px; border-radius: 6px; font-weight: bold; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; transition: background 0.2s, color 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)'; this.style.color='#fff'" onmouseout="this.style.background='rgba(255,255,255,0.08)'; this.style.color='#ccc'">Decline</button>
                    </form>
                </div>
            `;
            document.body.appendChild(toast);
            const existingBadge = document.querySelector('.lobby-pending-badge');
            if (existingBadge) {
                const count = parseInt(existingBadge.textContent) || 0;
                existingBadge.textContent = count + 1;
                existingBadge.style.display = 'inline-block';
            } else {
                const heading = document.querySelector('.lobby-friends-panel h3');
                if (heading) {
                    const badge = document.createElement('span');
                    badge.className = 'lobby-pending-badge';
                    badge.title = '1 pending requests';
                    badge.style.cssText = "background: #ef4444; color: white; font-size: 0.75rem; font-weight: bold; padding: 2px 8px; border-radius: 20px; box-shadow: 0 0 10px #ef4444; animation: badgePulse 1.5s infinite ease-in-out; display: inline-block; margin-left: 10px;";
                    badge.textContent = '1';
                    heading.appendChild(badge);
                }
            }
        });

        const toggleSearchBtn = document.getElementById('toggle-lobby-search-btn');
        const searchContainer = document.getElementById('lobby-friend-search-container');
        const lobbySearchInput = document.getElementById('lobby-friend-search-input');
        const lobbyFriendRows = document.querySelectorAll('.lobby-friend-row');
        const lobbyNoFriendsMessage = document.getElementById('lobby-no-friends-filtered');

        if (toggleSearchBtn && searchContainer) {
            toggleSearchBtn.addEventListener('click', () => {
                if (searchContainer.style.display === 'none') {
                    searchContainer.style.display = 'block';
                    searchContainer.offsetHeight;
                    searchContainer.style.opacity = '1';
                    searchContainer.style.transform = 'translateY(0)';
                    if (lobbySearchInput) lobbySearchInput.focus();
                } else {
                    searchContainer.style.opacity = '0';
                    searchContainer.style.transform = 'translateY(-10px)';
                    setTimeout(() => {
                        searchContainer.style.display = 'none';
                        if (lobbySearchInput) {
                            lobbySearchInput.value = '';
                            lobbySearchInput.dispatchEvent(new Event('input'));
                        }
                    }, 300);
                }
            });
        }

        function filterLobbyFriends() {
            const isOnlineOnly = document.getElementById('lobby-online-filter-checkbox')?.checked;
            const query = (document.getElementById('lobby-friend-search-input')?.value || '').toLowerCase().trim();
            let visibleCount = 0;
            lobbyFriendRows.forEach(row => {
                const nickname = row.getAttribute('data-nickname');
                const isOnline = row.getAttribute('data-online') === 'true';
                if (nickname.includes(query) && (!isOnlineOnly || isOnline)) {
                    row.style.display = 'flex';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            if (lobbyNoFriendsMessage) {
                if (visibleCount === 0 && lobbyFriendRows.length > 0) {
                    lobbyNoFriendsMessage.style.display = 'block';
                } else {
                    lobbyNoFriendsMessage.style.display = 'none';
                }
            }
        }

                        if (lobbySearchInput) {
                            lobbySearchInput.addEventListener('input', filterLobbyFriends);
                        }
                    
                        function switchLeaderboardTab(tab) {
                            const tabPlayers = document.getElementById('tab-top-players');
                            const tabFriends = document.getElementById('tab-my-friends');
                            const contentPlayers = document.getElementById('content-top-players');
                            const contentFriends = document.getElementById('content-my-friends');

                            if (tab === 'players') {
                                tabPlayers.style.color = '#c084fc';
                                tabPlayers.style.textShadow = '0 0 10px rgba(147, 51, 234, 0.7)';
                                tabFriends.style.color = 'rgba(192, 132, 252, 0.4)';
                                tabFriends.style.textShadow = 'none';
                                contentPlayers.style.display = 'flex';
                                contentFriends.style.display = 'none';
                            } else {
                                tabFriends.style.color = '#c084fc';
                                tabFriends.style.textShadow = '0 0 10px rgba(147, 51, 234, 0.7)';
                                tabPlayers.style.color = 'rgba(192, 132, 252, 0.4)';
                                tabPlayers.style.textShadow = 'none';
                                contentFriends.style.display = 'flex';
                                contentPlayers.style.display = 'none';
                            }
                        }

                    </script>
                    <script src="/js/achievements.js?v=1.7"></script>
                    <script src="/js/particles.js"></script>
                    <style>
                        @keyframes slideInUp {
                            from {
                                transform: translateY(100px);
                                opacity: 0;
                            }

                            to {
                                transform: translateY(0);
                                opacity: 1;
                            }
                        }

                        @keyframes spectatePulse {
                            0% {
                                box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
                            }

                            70% {
                                box-shadow: 0 0 0 6px rgba(168, 85, 247, 0);
                            }

                            100% {
                                box-shadow: 0 0 0 0 rgba(168, 85, 247, 0);
                            }
                        }
                    </style>
                    <script src="/js/volume-controls.js"></script>
                    <script src="/js/sounds.js"></script>
</body>

</html>
