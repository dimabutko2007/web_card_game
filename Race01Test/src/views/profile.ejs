<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Realms - Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css?v=1.2">
    <style>
        .profile-avatar-wrapper {
            position: relative;
            display: inline-block;
            cursor: pointer;
            width: 150px;
            height: 150px;
            margin-bottom: 20px;
            border-radius: 50%;
        }

        .profile-avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 4px solid var(--color-red);
            object-fit: cover;
            box-sizing: border-box;
        }

        .profile-avatar-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.6);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
            box-sizing: border-box;
        }

        .profile-avatar-wrapper:hover .profile-avatar-overlay {
            opacity: 1;
        }

        .stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin: 30px 0;
        }

        .stat-item h4 {
            color: var(--color-gold);
            font-size: 1.2rem;
        }

        .stat-item p {
            font-size: 2rem;
            font-weight: bold;
        }

        /* Nickname edit styles */
        .nickname-display {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .nickname-edit-btn {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.4);
            cursor: pointer;
            font-size: 1.1rem;
            padding: 5px;
            transition: color 0.3s, transform 0.3s;
            line-height: 1;
            margin-left: 10px;
        }

        .nickname-edit-btn:hover {
            color: var(--marvel-gold);
            transform: scale(1.2);
        }

        .nickname-edit-form {
            display: none;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 10px;
            animation: fadeIn 0.3s ease-out;
        }

        .nickname-edit-form.active {
            display: flex;
        }

        .nickname-edit-form input {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 8px 14px;
            border-radius: 8px;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s;
            width: 200px;
        }

        .nickname-edit-form input:focus {
            border-color: var(--marvel-gold);
        }

        .nickname-edit-form button {
            padding: 8px 16px;
            font-size: 0.9rem;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Outfit', sans-serif;
            font-weight: bold;
            transition: opacity 0.3s;
        }

        .avatar-option:hover,
        .avatar-option.selected {
            border-color: var(--color-red);
        }

        .nickname-edit-form button:hover {
            opacity: 0.85;
        }

        .nickname-save-btn {
            background: linear-gradient(45deg, #e9d5ff, #a78bfa);
            color: #1a1a1a;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nickname-cancel-btn {
            background: rgba(255, 255, 255, 0.15);
            color: white;
        }

        .alert-error {
            color: #ff5a5a;
            background: rgba(226, 54, 54, 0.15);
            border: 1px solid rgba(226, 54, 54, 0.3);
            padding: 10px 20px;
            border-radius: 10px;
            margin-bottom: 15px;
            font-weight: bold;
        }

        .alert-success {
            color: var(--color-gold);
            background: rgba(240, 165, 0, 0.15);
            border: 1px solid rgba(240, 165, 0, 0.3);
            padding: 10px 20px;
            border-radius: 10px;
            margin-bottom: 15px;
            font-weight: bold;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .rank-badge {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 50px;
            height: 50px;
            z-index: 10;
            background: rgba(26, 0, 51, 0.8);
            padding: 5px;
            border-radius: 8px;
            border: 1px solid rgba(140, 60, 200, 0.4);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
        }

        .match-row {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .match-cell {
            padding: 15px;
            text-align: center;
        }

        .status-victory {
            color: #4ade80;
            font-weight: bold;
        }

        .status-defeat {
            color: #ff5a5a;
            font-weight: bold;
        }

        .opponent-link {
            color: #e9d5ff;
            text-decoration: none;
        }

        .opponent-link:hover {
            text-decoration: underline;
        }

        .match-date {
            color: #aaa;
            font-size: 0.8rem;
        }

        @keyframes spectatePulse {
            0% {
                box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.7);
            }

            70% {
                box-shadow: 0 0 0 6px rgba(168, 85, 247, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(168, 85, 247, 0);
            }
        }

        .profile-avatar-playing {
            border-color: #c084fc !important;
        }

        .profile-avatar-online {
            border-color: #10b981 !important;
        }

        .profile-avatar-offline {
            border-color: #e9d5ff !important;
        }

        .friend-row-playing {
            border-left: 3px solid #c084fc !important;
            padding-left: 12px !important;
        }

        .friend-row-online {
            border-left: 3px solid #10b981 !important;
            padding-left: 12px !important;
        }

        .friend-row-offline {
            border-left: none !important;
            padding-left: 10px !important;
        }

        .friend-avatar-playing {
            border-color: #c084fc !important;
        }

        .friend-avatar-online {
            border-color: #10b981 !important;
        }

        .friend-avatar-offline {
            border-color: #e9d5ff !important;
        }

        .friend-name-playing {
            color: #f3e8ff;
        }

        .friend-name-online {
            color: #e8f5e9;
        }

        .friend-name-offline {
            color: #e9d5ff;
        }

        .friend-name-playing:hover,
        .friend-name-online:hover,
        .friend-name-offline:hover {
            color: #a78bfa !important;
        }

        /* Nickname hover reveal — handled via JS */
        .nickname-h2-clip {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 280px;
        }

        .nickname-container-clip {
            overflow: visible;
        }

        #nickname-status-badges {
            transition: opacity 0.25s ease, max-width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
        }

        .rank-icon-large {
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.3s ease;
            cursor: help;
        }

        .rank-icon-large:hover {
            transform: scale(1.18) rotate(5deg);
            filter: drop-shadow(0 0 15px rgba(192, 132, 252, 0.7));
            z-index: 100;
            position: relative;
        }

        #nickname-container {
            overflow: visible !important;
        }

        #nickname-container-parent {
            overflow: visible !important;
        }

        .auth-card {
            overflow: visible !important;
        }

        .nickname-edit-btn {
            transition: opacity 0.2s ease;
            overflow: hidden;
        }
    </style>
</head>

<body class="auth-page">
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="popup-notification-box" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(40, 10, 10, 0.95); border: 2px solid #ef4444; border-radius: 12px; padding: 15px 20px; min-width: 280px; max-width: 380px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif; text-align: left;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 15px;">
                <h4 style="color: #ef4444; margin: 0; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold; display: flex; align-items: center; gap: 8px;">
                    <span>⚠️</span> Error
                </h4>
                <button onclick="this.parentElement.parentElement.remove()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0;">&times;</button>
            </div>
            <div style="color: #fee2e2; font-size: 1rem; font-weight: 500; margin-top: 5px;">
                <%= error %>
            </div>
        </div>
        <script>setTimeout(() => { const b = document.querySelector('.popup-notification-box'); if (b) b.remove(); }, 5000);</script>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="popup-notification-box" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(20, 40, 20, 0.95); border: 2px solid #4ade80; border-radius: 12px; padding: 15px 20px; min-width: 280px; max-width: 380px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif; text-align: left;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 15px;">
                <h4 style="color: #4ade80; margin: 0; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold; display: flex; align-items: center; gap: 8px;">
                    <span>✓</span> Success
                </h4>
                <button onclick="this.parentElement.parentElement.remove()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0;">&times;</button>
            </div>
            <div style="color: #e8f5e9; font-size: 1rem; font-weight: 500; margin-top: 5px;">
                <%= success %>
            </div>
        </div>
        <script>setTimeout(() => { const b = document.querySelector('.popup-notification-box'); if (b) b.remove(); }, 5000);</script>
    <% } %>

    <canvas id="bg-particles" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>

    <div class="auth-wrapper">
        <div class="auth-card" style="text-align: center; margin: 40px 0;">
            <div style="text-align: left; margin-bottom: 20px;">
                <a href="/lobby" style="color: white; text-decoration: none; font-size: 0.9rem;">&larr; Back to Lobby</a>
            </div>

            <% const userRank = User.getRank(user.elo); %>

            <% if (isOwnProfile) { %>
                <form action="/profile/avatar" method="POST" enctype="multipart/form-data" id="avatar-form">
                    <div class="profile-avatar-wrapper" onclick="document.getElementById('avatar-input').click()" style="cursor: pointer; position: relative; display: inline-block;">
                        <img src="<%= user.avatar %>" alt="Avatar" class="profile-avatar <%= (user.activeGameId || user.isPlaying) ? 'profile-avatar-playing' : (user.isOnline ? 'profile-avatar-online' : 'profile-avatar-offline') %>" id="avatar-preview" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 3px solid #e9d5ff;">
                        <div class="profile-avatar-overlay">Change</div>
                        <% if (user.activeGameId || user.isPlaying) { %>
                            <span style="position: absolute; bottom: 10px; right: 10px; width: 22px; height: 22px; background-color: #c084fc; border: 3px solid #1a022d; border-radius: 50%; box-shadow: 0 0 12px #c084fc; display: block; animation: spectatePulse 1.5s infinite;"></span>
                        <% } else if (user.isOnline) { %>
                            <span style="position: absolute; bottom: 10px; right: 10px; width: 22px; height: 22px; background-color: #10b981; border: 3px solid #1a022d; border-radius: 50%; box-shadow: 0 0 12px #10b981; display: block;"></span>
                        <% } %>
                    </div>
                    <input type="file" name="avatar" id="avatar-input" accept="image/jpeg, image/png, image/gif" style="display: none;" onchange="previewAvatar(event)">
                    <button type="submit" class="btn avatar-save-btn" id="avatar-save-btn" style="display: none; margin: 15px auto; padding: 8px 20px; background: linear-gradient(45deg, #e9d5ff, #a78bfa); border: none; border-radius: 8px; color: #1a1a1a; cursor: pointer; font-weight: bold;">Upload Avatar</button>
                </form>
            <% } else { %>
                <div style="display: block; margin-bottom: 20px;">
                    <div class="profile-avatar-wrapper" style="cursor: default; position: relative; display: inline-block;">
                        <img src="<%= user.avatar %>" alt="Avatar" class="profile-avatar <%= (user.activeGameId || user.isPlaying) ? 'profile-avatar-playing' : (user.isOnline ? 'profile-avatar-online' : 'profile-avatar-offline') %>" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 3px solid #e9d5ff;">
                        <% if (user.activeGameId || user.isPlaying) { %>
                            <span style="position: absolute; bottom: 10px; right: 10px; width: 22px; height: 22px; background-color: #c084fc; border: 3px solid #1a022d; border-radius: 50%; box-shadow: 0 0 12px #c084fc; display: block; animation: spectatePulse 1.5s infinite;"></span>
                        <% } else if (user.isOnline) { %>
                            <span style="position: absolute; bottom: 10px; right: 10px; width: 22px; height: 22px; background-color: #10b981; border: 3px solid #1a022d; border-radius: 50%; box-shadow: 0 0 12px #10b981; display: block;"></span>
                        <% } %>
                    </div>
                </div>
            <% } %>

            <div id="nickname-container-parent" style="position: relative; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 15px; width: 100%;">
                <div class="nickname-display nickname-container-clip" id="nickname-container" style="display: flex; align-items: center; justify-content: center; max-width: 100%; gap: 10px; flex-wrap: nowrap;">
                    <img src="/assets/ranks/<%= userRank.icon %>" alt="<%= userRank.name %>" title="<%= userRank.name %>" class="rank-icon-large" style="width: 70px; height: 70px; flex-shrink: 0; border-radius: 0;">
                    <h2 id="nickname-text" class="nickname-h2-clip" title="<%= user.nickname %>" style="font-size: 2.5rem; margin: 0; color: #e9d5ff; text-transform: uppercase; letter-spacing: 2px; min-width: 0;">
                        <%= user.nickname %>
                    </h2>
                    <div id="nickname-status-badges" style="display: inline-flex; align-items: center; gap: 8px; flex-shrink: 0; max-width: 300px;">
                        <% if (user.activeGameId || user.isPlaying) { %>
                            <span style="font-size: 0.85rem; background: rgba(168, 85, 247, 0.15); border: 1px solid rgba(168, 85, 247, 0.35); color: #c084fc; padding: 4px 10px; border-radius: 8px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap;">Playing</span>
                            <% if (user.activeGameId) { %>
                                <a href="/game/<%= user.activeGameId %>" class="spectate-badge-link" style="display: inline-flex; align-items: center; gap: 5px; text-decoration: none; background: linear-gradient(135deg, #a855f7, #6b21a8); color: white; font-size: 0.8rem; font-weight: bold; padding: 5px 12px; border-radius: 8px; border: 1px solid rgba(167, 139, 250, 0.4); box-shadow: 0 0 10px rgba(168, 85, 247, 0.4); text-transform: uppercase; letter-spacing: 0.5px; transition: all 0.2s ease; white-space: nowrap;" onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 0 15px rgba(168, 85, 247, 0.7)';" onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 0 10px rgba(168, 85, 247, 0.4)';">
                                    👁️ Spectate
                                </a>
                            <% } %>
                        <% } else if (user.isOnline) { %>
                            <span style="font-size: 0.85rem; background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16, 185, 129, 0.3); color: #10b981; padding: 4px 10px; border-radius: 8px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap;">Online</span>
                        <% } else { %>
                            <span style="font-size: 0.85rem; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.15); color: #aaa; padding: 4px 10px; border-radius: 8px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap;">Offline</span>
                        <% } %>
                    </div>
                </div>
                <% if (isOwnProfile) { %>
                    <button class="nickname-edit-btn" onclick="toggleNicknameEdit()" title="Change nickname" style="background: none; border: none; color: #e9d5ff; cursor: pointer; font-size: 1.2rem; flex-shrink: 0; padding: 5px;">&#9998;</button>
                <% } %>
            </div>

            <% if (isOwnProfile) { %>
                <form action="/profile/nickname" method="POST" class="nickname-edit-form" id="nickname-edit-form" style="margin-top: 15px;">
                    <input type="text" name="nickname" id="nickname-input" value="<%= user.nickname %>" minlength="4" maxlength="20" pattern="[a-zA-Z0-9_]+" required style="padding: 10px; border-radius: 5px; border: 1px solid #e9d5ff; background: rgba(0,0,0,0.5); color: white;">
                    <button type="submit" class="nickname-save-btn">Save</button>
                    <button type="button" class="nickname-cancel-btn" onclick="toggleNicknameEdit()">Cancel</button>
                </form>
            <% } %>

            <% if (isOwnProfile) { %>
                <p style="color: #aaa; margin-bottom: 25px;"><%= user.email %></p>
            <% } else { %>
                <% if (typeof relation !== 'undefined') { %>
                    <div style="margin-bottom: 25px;">
                        <% if (relation === null) { %>
                            <form action="/profile/<%= user.nickname %>/add-friend" method="POST" style="display: inline;">
                                <button type="submit" class="btn" style="background: linear-gradient(45deg, #a78bfa, #7c3aed); color: white; border: none; padding: 10px 24px; border-radius: 8px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 10px rgba(167, 139, 250, 0.3);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                                    Add Friend
                                </button>
                            </form>
                        <% } else if (relation.status === 'accepted') { %>
                            <form action="/profile/<%= user.nickname %>/remove-friend" method="POST" style="display: inline;">
                                <button type="submit" class="btn" style="background: linear-gradient(45deg, #ef4444, #b91c1c); color: white; border: none; padding: 10px 24px; border-radius: 8px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                                    Remove Friend
                                </button>
                            </form>
                        <% } else if (relation.status === 'pending' && relation.sender_id === user.id) { %>
                            <div style="display: flex; gap: 10px; justify-content: center; align-items: center;">
                                <form action="/profile/<%= user.nickname %>/accept-friend" method="POST" style="display: inline;">
                                    <button type="submit" class="btn" style="background: linear-gradient(45deg, #4ade80, #15803d); color: white; border: none; padding: 10px 24px; border-radius: 8px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                                        Accept
                                    </button>
                                </form>
                                <form action="/profile/<%= user.nickname %>/decline-friend" method="POST" style="display: inline;">
                                    <button type="submit" class="btn" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.3); padding: 10px 24px; border-radius: 8px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                                        Decline
                                    </button>
                                </form>
                            </div>
                        <% } else if (relation.status === 'pending') { %>
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
                                <span style="color: #aaa; font-size: 0.9rem; font-style: italic;">Friend request pending...</span>
                                <form action="/profile/<%= user.nickname %>/remove-friend" method="POST" style="display: inline;">
                                    <button type="submit" class="btn" style="background: rgba(255, 255, 255, 0.1); color: #ccc; border: 1px solid rgba(255, 255, 255, 0.2); padding: 8px 18px; border-radius: 6px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                                        Cancel Request
                                    </button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                <% } else { %>
                    <div style="margin-bottom: 25px;"></div>
                <% } %>
            <% } %>

            <div class="stats" style="display: flex; justify-content: space-around; gap: 10px; background: rgba(255,255,255,0.05); padding: 20px; border-radius: 15px;">
                <div class="stat-item">
                    <h4 style="color: #aaa; margin-bottom: 5px; font-size: 0.8rem;">Rating (Elo)</h4>
                    <p style="font-size: 1.2rem; font-weight: bold;"><%= user.elo %></p>
                </div>
                <div class="stat-item">
                    <h4 style="color: #aaa; margin-bottom: 5px; font-size: 0.8rem;">Wins</h4>
                    <p style="font-size: 1.2rem; font-weight: bold;"><%= user.wins %></p>
                </div>
                <div class="stat-item">
                    <h4 style="color: #aaa; margin-bottom: 5px; font-size: 0.8rem;">Losses</h4>
                    <p style="font-size: 1.2rem; font-weight: bold;"><%= user.losses %></p>
                </div>
                <div class="stat-item">
                    <h4 style="color: #aaa; margin-bottom: 5px; font-size: 0.8rem;">Win Rate</h4>
                    <p style="font-size: 1.2rem; font-weight: bold;">
                        <% const total = user.wins + user.losses; %>
                        <% const winrate = total > 0 ? Math.round((user.wins / total) * 100) : 0; %>
                        <%= winrate %>%
                    </p>
                </div>
            </div>

            <div class="match-history" style="margin-top: 40px; text-align: left;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid rgba(233, 213, 255, 0.2); padding-bottom: 10px;">
                    <h3 style="color: #e9d5ff; text-transform: uppercase; letter-spacing: 2px; margin: 0;">Recent Battles</h3>
                    <% if (typeof matches !== 'undefined' && matches.length > 0) { %>
                        <a href="/profile/<%= user.nickname %>/history" style="color: #a78bfa; text-decoration: none; font-size: 0.85rem; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">View All &rarr;</a>
                    <% } %>
                </div>

                <% if (typeof matches !== 'undefined' && matches.length > 0) { %>
                    <div style="background: rgba(0,0,0,0.3); border-radius: 15px; overflow: hidden; border: 1px solid rgba(233, 213, 255, 0.1);">
                        <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                            <thead>
                                <tr style="background: rgba(233, 213, 255, 0.05); color: #aaa; text-transform: uppercase; font-size: 0.75rem;">
                                    <th style="padding: 12px; text-align: center;">Result</th>
                                    <th style="padding: 12px; text-align: center;">Opponent</th>
                                    <th style="padding: 12px; text-align: center;">Elo</th>
                                    <th style="padding: 12px; text-align: center;">Date & Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% matches.forEach(match => { %>
                                    <% const isWinner = match.winner_id === user.id; %>
                                    <% const statusClass = isWinner ? 'status-victory' : 'status-defeat'; %>
                                    <tr class="match-row">
                                        <td class="match-cell <%= statusClass %>">
                                            <%= isWinner ? 'VICTORY' : 'DEFEAT' %>
                                        </td>
                                        <td class="match-cell">
                                            <a href="/profile/<%= isWinner ? match.loser_nickname : match.winner_nickname %>" class="opponent-link">
                                                <%= isWinner ? match.loser_nickname : match.winner_nickname %>
                                            </a>
                                        </td>
                                        <td class="match-cell <%= statusClass %>">
                                            <%= isWinner ? '+' : '-' %><%= match.elo_change %>
                                        </td>
                                        <td class="match-cell match-date">
                                            <% const d = new Date(match.played_at); %>
                                            <%= d.toLocaleDateString() %> <%= d.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 30px; background: rgba(255,255,255,0.02); border-radius: 15px; border: 1px dashed rgba(233, 213, 255, 0.2);">
                        <p style="color: #666; font-style: italic; margin: 0;">No battles recorded in the archives yet.</p>
                    </div>
                <% } %>
            </div>

            <div class="friends-list-widget" style="margin-top: 40px; text-align: left;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid rgba(233, 213, 255, 0.2); padding-bottom: 10px;">
                    <h3 style="color: #e9d5ff; text-transform: uppercase; letter-spacing: 2px; margin: 0;">Friends</h3>
                    <% if (typeof friends !== 'undefined') { %>
                        <a href="/profile/<%= user.nickname %>/friends" style="color: #a78bfa; text-decoration: none; font-size: 0.85rem; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">View Friends (<%= friends.length %>) &rarr;</a>
                    <% } %>
                </div>

                <% if (typeof friends !== 'undefined' && friends.length > 0) { %>
                    <div style="background: rgba(0,0,0,0.3); border-radius: 15px; overflow: hidden; border: 1px solid rgba(233, 213, 255, 0.1); padding: 10px 15px;">
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            <% const topFriends = [...friends].sort((a, b) => b.elo - a.elo).slice(0, 5); %>
                            <% topFriends.forEach(friend => { %>
                                <% const friendRank = User.getRank(friend.elo); %>
                                <div class="<%= (friend.activeGameId || friend.isPlaying) ? 'friend-row-playing' : (friend.isOnline ? 'friend-row-online' : 'friend-row-offline') %>" style="display: flex; align-items: center; gap: 15px; padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
                                    <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0;">
                                        <div style="position: relative; display: inline-block; width: 40px; height: 40px; flex-shrink: 0;">
                                            <img src="<%= friend.avatar %>" alt="<%= friend.nickname %>" class="<%= (friend.activeGameId || friend.isPlaying) ? 'friend-avatar-playing' : (friend.isOnline ? 'friend-avatar-online' : 'friend-avatar-offline') %>" style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid #e9d5ff; object-fit: cover;">
                                            <% if (friend.activeGameId || friend.isPlaying) { %>
                                                <span style="position: absolute; bottom: 0; right: 0; width: 10px; height: 10px; background-color: #c084fc; border: 2px solid #1a022d; border-radius: 50%; box-shadow: 0 0 6px #c084fc; display: block; animation: spectatePulse 1.5s infinite;"></span>
                                            <% } else if (friend.isOnline) { %>
                                                <span style="position: absolute; bottom: 0; right: 0; width: 10px; height: 10px; background-color: #10b981; border: 2px solid #1a022d; border-radius: 50%; box-shadow: 0 0 6px #10b981; display: block;"></span>
                                            <% } %>
                                        </div>
                                        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                                            <a href="/profile/<%= friend.nickname %>" class="<%= (friend.activeGameId || friend.isPlaying) ? 'friend-name-playing' : (friend.isOnline ? 'friend-name-online' : 'friend-name-offline') %>" style="text-decoration: none; font-size: 1.1rem; font-weight: bold; transition: color 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px;">
                                                <%= friend.nickname %>
                                            </a>
                                            <% if (friend.activeGameId || friend.isPlaying) { %>
                                                <span style="font-size: 0.68rem; background: rgba(168, 85, 247, 0.15); border: 1px solid rgba(168, 85, 247, 0.35); color: #c084fc; padding: 2px 6px; border-radius: 6px; display: inline-block;">playing</span>
                                            <% } %>
                                            <% if (friend.activeGameId) { %>
                                                <a href="/game/<%= friend.activeGameId %>" class="spectate-badge-link" style="display: inline-flex; align-items: center; gap: 4px; text-decoration: none; background: linear-gradient(135deg, #a855f7, #6b21a8); color: white; font-size: 0.7rem; font-weight: bold; padding: 3px 8px; border-radius: 6px; border: 1px solid rgba(167, 139, 250, 0.4); box-shadow: 0 0 8px rgba(168, 85, 247, 0.3); text-transform: uppercase; letter-spacing: 0.5px; transition: all 0.2s ease;" onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 0 12px rgba(168, 85, 247, 0.6)';" onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 0 8px rgba(168, 85, 247, 0.3)';">
                                                    <span style="font-size: 0.8rem; line-height: 1;">👁️</span>Spec
                                                </a>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div style="display: flex; align-items: center; justify-content: flex-end; gap: 8px; width: 110px; flex-shrink: 0;">
                                        <img src="/assets/ranks/<%= friendRank.icon %>" alt="<%= friendRank.name %>" title="<%= friendRank.name %>" style="width: 32px; height: 32px; border-radius: 0;">
                                        <span style="color: #aaa; font-size: 0.85rem; width: 65px; text-align: right;"><%= friend.elo %> ELO</span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 30px; background: rgba(255,255,255,0.02); border-radius: 15px; border: 1px dashed rgba(233, 213, 255, 0.2);">
                        <p style="color: #666; font-style: italic; margin: 0;">No friends added yet.</p>
                    </div>
                <% } %>
            </div>

        </div>
    </div>

    <script>
        function previewAvatar(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('avatar-preview').src = e.target.result;
                }
                reader.readAsDataURL(file);
                document.getElementById('avatar-save-btn').style.display = 'block';
            }
        }

        function toggleNicknameEdit() {
            const form = document.getElementById('nickname-edit-form');
            const input = document.getElementById('nickname-input');
            form.classList.toggle('active');
            if (form.classList.contains('active')) {
                input.focus();
                input.select();
            }
        }

        // Clear query parameters from URL after load so they don't persist on reload
        window.addEventListener('load', () => {
            if (window.location.search.includes('error=') || window.location.search.includes('success=')) {
                const url = new URL(window.location);
                url.searchParams.delete('error');
                url.searchParams.delete('success');
                window.history.replaceState({}, document.title, url.pathname + url.search);
            }
        });

        // Nickname hover reveal — JS approach for reliable inline style override
        (function () {
            const container = document.getElementById('nickname-container');
            const h2 = document.getElementById('nickname-text');
            if (!container || !h2) return;

            // Simple logic: no movement, no hiding. 
            // We just ensure the nickname doesn't cause jumps.
        })();
    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        // Join personal user room to receive notifications
        socket.emit('joinUserRoom', { userId: '<%= session.userId %>' });

        // Listen for real-time friend requests
        socket.on('friendRequestReceived', (data) => {
            // Check if toast already exists
            const existing = document.getElementById('friend-request-notification-box');
            if (existing) {
                existing.remove();
            }

            const toast = document.createElement('div');
            toast.id = 'friend-request-notification-box';
            toast.style.cssText = "position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: rgba(26, 0, 51, 0.95); border: 2px solid #a78bfa; border-radius: 12px; padding: 15px 20px; max-width: 350px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideInUp 0.5s cubic-bezier(0.1, 0.8, 0.3, 1); font-family: 'Outfit', sans-serif;";

            toast.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; gap: 15px;">
                    <h4 style="color: #e9d5ff; margin: 0; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">New Friend Request</h4>
                    <button onclick="document.getElementById('friend-request-notification-box').remove()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.4rem; line-height: 1; padding: 0; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#aaa'">&times;</button>
                </div>
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px;">
                    <img src="${data.avatar}" alt="Avatar" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid #e9d5ff;">
                    <div>
                        <a href="/profile/${data.nickname}" style="color: #e9d5ff; text-decoration: none; font-weight: bold; font-size: 1rem; display: block; transition: color 0.2s;" onmouseover="this.style.color='#a78bfa'" onmouseout="this.style.color='#e9d5ff'">${data.nickname}</a>
                        <span style="color: #aaa; font-size: 0.8rem; display: block; margin-top: 2px;">wants to be your friend!</span>
                    </div>
                </div>
                <div style="display: flex; gap: 10px;">
                    <form action="/profile/${data.nickname}/accept-friend" method="POST" style="flex: 1; margin: 0;">
                        <button type="submit" style="width: 100%; background: linear-gradient(45deg, #4ade80, #15803d); color: white; border: none; padding: 8px 12px; border-radius: 6px; font-weight: bold; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">Accept</button>
                    </form>
                    <form action="/profile/${data.nickname}/decline-friend" method="POST" style="flex: 1; margin: 0;">
                        <button type="submit" style="width: 100%; background: rgba(255,255,255,0.08); color: #ccc; border: 1px solid rgba(255,255,255,0.15); padding: 8px 12px; border-radius: 6px; font-weight: bold; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; transition: background 0.2s, color 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.15)'; this.style.color='#fff'" onmouseout="this.style.background='rgba(255,255,255,0.08)'; this.style.color='#ccc'">Decline</button>
                    </form>
                </div>
            `;
            document.body.appendChild(toast);
        });
    </script>
    <script src="/js/particles.js"></script>
    <style>
        @keyframes slideInUp {
            from {
                transform: translateY(100px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
    </style>
    <script src="/js/volume-controls.js"></script>
    <script src="/js/sounds.js"></script>
</body>

</html>