<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Great Battle - Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .profile-card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 40px;
            max-width: 600px;
            margin: 50px auto;
            text-align: center;
        }

        .profile-avatar-wrapper {
            position: relative;
            display: inline-block;
            cursor: pointer;
            width: 150px;
            height: 150px;
            margin-bottom: 20px;
            border-radius: 50%;
        }

        .profile-avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 4px solid var(--marvel-red);
            object-fit: cover;
            box-sizing: border-box;
        }

        .profile-avatar-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: rgba(0,0,0,0.6);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
            box-sizing: border-box;
        }

        .profile-avatar-wrapper:hover .profile-avatar-overlay {
            opacity: 1;
        }

        .stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin: 30px 0;
        }

        .stat-item h4 {
            color: var(--marvel-gold);
            font-size: 1.2rem;
        }

        .stat-item p {
            font-size: 2rem;
            font-weight: bold;
        }

        /* Nickname edit styles */
        .nickname-display {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .nickname-edit-btn {
            background: none;
            border: none;
            color: rgba(255,255,255,0.4);
            cursor: pointer;
            font-size: 1.1rem;
            padding: 5px;
            transition: color 0.3s, transform 0.3s;
            line-height: 1;
        }

        .nickname-edit-btn:hover {
            color: var(--marvel-gold);
            transform: scale(1.2);
        }

        .nickname-edit-form {
            display: none;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 10px;
            animation: fadeIn 0.3s ease-out;
        }

        .nickname-edit-form.active {
            display: flex;
        }

        .nickname-edit-form input {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            padding: 8px 14px;
            border-radius: 8px;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s;
            width: 200px;
        }

        .nickname-edit-form input:focus {
            border-color: var(--marvel-gold);
        }

        .nickname-edit-form button {
            padding: 8px 16px;
            font-size: 0.9rem;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Outfit', sans-serif;
            font-weight: bold;
            transition: opacity 0.3s;
        }

        .nickname-edit-form button:hover {
            opacity: 0.85;
        }

        .nickname-save-btn {
            background: linear-gradient(45deg, var(--marvel-red), #ff5a5a);
            color: white;
        }

        .nickname-cancel-btn {
            background: rgba(255,255,255,0.15);
            color: white;
        }

        .alert-error {
            color: #ff5a5a;
            background: rgba(226, 54, 54, 0.15);
            border: 1px solid rgba(226, 54, 54, 0.3);
            padding: 10px 20px;
            border-radius: 10px;
            margin-bottom: 15px;
            font-weight: bold;
        }

        .alert-success {
            color: var(--marvel-gold);
            background: rgba(240, 165, 0, 0.15);
            border: 1px solid rgba(240, 165, 0, 0.3);
            padding: 10px 20px;
            border-radius: 10px;
            margin-bottom: 15px;
            font-weight: bold;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>

<body>
    <div class="container">
        <a href="/lobby" style="color: white; text-decoration: none;">&larr; Back to Lobby</a>

        <div class="profile-card">
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert-error"><%= error %></div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert-success"><%= success %></div>
            <% } %>

            <form action="/profile/avatar" method="POST" enctype="multipart/form-data" id="avatar-form">
                <div class="profile-avatar-wrapper" onclick="document.getElementById('avatar-input').click()">
                    <img src="<%= user.avatar %>" alt="Avatar" class="profile-avatar" id="avatar-preview">
                    <div class="profile-avatar-overlay">
                        Change
                    </div>
                </div>
                <input type="file" name="avatar" id="avatar-input" accept="image/jpeg, image/png, image/gif" style="display: none;" onchange="previewAvatar(event)">
                <button type="submit" class="btn avatar-save-btn" id="avatar-save-btn" style="display: none; margin: 10px auto; padding: 8px 20px; font-size: 0.9rem; background: linear-gradient(45deg, var(--marvel-red), #ff5a5a); border: none; border-radius: 8px; color: white; cursor: pointer; font-family: 'Outfit', sans-serif; font-weight: bold;">Upload Avatar</button>
            </form>

            <div class="nickname-display">
                <h1 id="nickname-text"><%= user.nickname %></h1>
                <button class="nickname-edit-btn" onclick="toggleNicknameEdit()" title="Change nickname">&#9998;</button>
            </div>

            <form action="/profile/nickname" method="POST" class="nickname-edit-form" id="nickname-edit-form">
                <input type="text" name="nickname" id="nickname-input" value="<%= user.nickname %>"
                       minlength="4" maxlength="20" pattern="[a-zA-Z0-9_]+" required
                       placeholder="New nickname">
                <button type="submit" class="nickname-save-btn">Save</button>
                <button type="button" class="nickname-cancel-btn" onclick="toggleNicknameEdit()">Cancel</button>
            </form>

            <p style="color: #aaa;">
                <%= user.email %>
            </p>

            <div class="stats">
                <div class="stat-item">
                    <h4>Rating (Elo)</h4>
                    <p>
                        <%= user.elo %>
                    </p>
                </div>
                <div class="stat-item">
                    <h4>Wins</h4>
                    <p>
                        <%= user.wins %>
                    </p>
                </div>
                <div class="stat-item">
                    <h4>Losses</h4>
                    <p>
                        <%= user.losses %>
                    </p>
                </div>
                <div class="stat-item">
                    <h4>Win Rate</h4>
                    <p>
                        <% const total=user.wins + user.losses; const winrate=total> 0 ? Math.round((user.wins / total)
                            * 100) : 0;
                            %>
                            <%= winrate %>%
                    </p>
                </div>
            </div>


        </div>
    </div>
    <script>
        function previewAvatar(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatar-preview').src = e.target.result;
                }
                reader.readAsDataURL(file);
                document.getElementById('avatar-save-btn').style.display = 'block';
            }
        }

        function toggleNicknameEdit() {
            const form = document.getElementById('nickname-edit-form');
            const input = document.getElementById('nickname-input');
            form.classList.toggle('active');
            if (form.classList.contains('active')) {
                input.focus();
                input.select();
            }
        }
    </script>
</body>

</html>