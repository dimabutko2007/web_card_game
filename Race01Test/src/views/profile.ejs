<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Great Battle - Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .profile-card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 40px;
            max-width: 600px;
            margin: 50px auto;
            text-align: center;
        }

        .profile-avatar-wrapper {
            position: relative;
            display: inline-block;
            cursor: pointer;
            width: 150px;
            height: 150px;
            margin-bottom: 20px;
            border-radius: 50%;
        }

        .profile-avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 4px solid var(--marvel-red);
            object-fit: cover;
            box-sizing: border-box;
        }

        .profile-avatar-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: rgba(0,0,0,0.6);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
            box-sizing: border-box;
        }

        .profile-avatar-wrapper:hover .profile-avatar-overlay {
            opacity: 1;
        }

        .stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin: 30px 0;
        }

        .stat-item h4 {
            color: var(--marvel-gold);
            font-size: 1.2rem;
        }

        .stat-item p {
            font-size: 2rem;
            font-weight: bold;
        }

        .avatar-selection {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

        .avatar-option {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid transparent;
            transition: border 0.3s;
        }

        .avatar-option:hover,
        .avatar-option.selected {
            border-color: var(--marvel-red);
        }
    </style>
</head>

<body>
    <div class="container">
        <a href="/lobby" style="color: white; text-decoration: none;">← Back to Lobby</a>

        <div class="profile-card">
            <% if (typeof error !== 'undefined' && error) { %>
                <div style="color: red; margin-bottom: 15px; font-weight: bold;"><%= error %></div>
            <% } %>

            <div class="profile-avatar-wrapper" onclick="document.getElementById('avatar-input').click()">
                <img src="<%= user.avatar %>" alt="Avatar" class="profile-avatar" id="avatar-preview">
                <div class="profile-avatar-overlay">
                    Change
                </div>
            </div>
            <h1>
                <%= user.nickname %>
            </h1>
            <p style="color: #aaa;">
                <%= user.email %>
            </p>

            <div class="stats">
                <div class="stat-item">
                    <h4>Rating (Elo)</h4>
                    <p>
                        <%= user.elo %>
                    </p>
                </div>
                <div class="stat-item">
                    <h4>Wins</h4>
                    <p>
                        <%= user.wins %>
                    </p>
                </div>
                <div class="stat-item">
                    <h4>Losses</h4>
                    <p>
                        <%= user.losses %>
                    </p>
                </div>
                <div class="stat-item">
                    <h4>Win Rate</h4>
                    <p>
                        <% const total=user.wins + user.losses; const winrate=total> 0 ? Math.round((user.wins / total)
                            * 100) : 0;
                            %>
                            <%= winrate %>%
                    </p>
                </div>
            </div>

            <form action="/profile/avatar" method="POST" enctype="multipart/form-data" style="margin-top: 20px;" id="avatar-form">
                <input type="file" name="avatar" id="avatar-input" accept="image/jpeg, image/png, image/gif" style="display: none;" onchange="previewAvatar(event)">
                <button type="submit" class="btn" style="padding: 10px 20px; font-size: 1rem; background: linear-gradient(45deg, var(--marvel-red), #ff5a5a); border: none; border-radius: 5px; color: white; cursor: pointer; font-family: 'Outfit', sans-serif; font-weight: bold;">Save Profile</button>
            </form>
        </div>
    </div>
    <script>
        function previewAvatar(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatar-preview').src = e.target.result;
                }
                reader.readAsDataURL(file);
            }
        }
    </script>
</body>

</html>